---
import { getUiEntry } from "../../data/content";

interface Props {
  label?: string;
}

const uiEntry = await getUiEntry("labels");
const ui = uiEntry.data;
const { label = ui.printToolbar.defaultLabel } = Astro.props;
---

<div class="doc-toolbar screen-only">
  <span class="muted">{label}</span>
  <button type="button" onclick="window.print()">{ui.printToolbar.printButtonLabel}</button>
</div>
