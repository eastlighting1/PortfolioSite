---
import { getUiEntry } from "../../data/content";
import ExternalLinks from "../common/ExternalLinks.astro";
import { type Locale } from "../../data/i18n";

interface Props {
  project: any;
  locale?: Locale;
}

const { project, locale = "ko" } = Astro.props;
const uiEntry = await getUiEntry("labels", locale);
const ui = uiEntry.data;
---

<section class="detail-hero" data-reveal="1">
  <div class="eyebrow">{ui.project.detailEyebrow}</div>
  <h1 class="section-title">{project.data.title}</h1>
  <p class="section-lead">{project.data.summary}</p>
  <div class="meta-list">
    <div class="meta-item">
      <span>{ui.project.fieldLabels.type}</span>
      <span>{project.data.type}</span>
    </div>
    <div class="meta-item">
      <span>{ui.project.fieldLabels.year}</span>
      <span>{project.data.year}</span>
    </div>
    <div class="meta-item">
      <span>{ui.project.fieldLabels.primaryRole}</span>
      <span>{project.data.role}</span>
    </div>
    <div class="meta-item">
      <span>{ui.project.fieldLabels.roles}</span>
      <span>{project.data.roles.join(", ")}</span>
    </div>
  </div>
  <div class="tag-row" style="margin-top: 1rem;">
    {project.data.tags.map((tag: string) => (
      <span class="tag-chip">{tag}</span>
    ))}
  </div>
  <div class="meta-row" style="margin-top: 1rem;">
    {project.data.metrics.map((metric: string) => (
      <span class="metric-badge">{metric}</span>
    ))}
  </div>
  <ExternalLinks
    locale={locale}
    links={[
      { label: ui.project.linkLabels.repo, href: project.data.repoUrl },
      { label: ui.project.linkLabels.demo, href: project.data.demoUrl },
      { label: ui.project.linkLabels.paper, href: project.data.paperUrl },
      { label: ui.project.linkLabels.slides, href: project.data.slidesUrl }
    ]}
  />
</section>
