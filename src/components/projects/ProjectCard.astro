---
import { getUiEntry } from "../../data/content";
import ExternalLinks from "../common/ExternalLinks.astro";
import { withBase } from "../../data/site";
import { entrySlug } from "../../data/content";
import ProjectQuickPreview from "./ProjectQuickPreview.astro";
import { localizePath, type Locale } from "../../data/i18n";

interface Props {
  project: any;
  dataReveal?: string;
  locale?: Locale;
}

const { project, dataReveal = "1", locale = "ko" } = Astro.props;
const href = withBase(localizePath(`projects/${entrySlug(project)}/`, locale));
const uiEntry = await getUiEntry("labels", locale);
const ui = uiEntry.data;
---

<article class="project-card" data-reveal={dataReveal}>
  <span class="small-label">{project.data.type} | {project.data.year}</span>
  <h3>{project.data.title}</h3>
  <p class="muted">{project.data.summary}</p>
  <div class="meta-row">
    <span class="tag-chip">{project.data.role}</span>
    {project.data.metrics.map((metric: string) => (
      <span class="metric-badge">{metric}</span>
    ))}
  </div>
  <div class="tag-row" style="margin-top: 1rem;">
    {project.data.tags.map((tag: string) => (
      <span class="tag-chip">{tag}</span>
    ))}
  </div>
  <ExternalLinks
    locale={locale}
    links={[
      { label: ui.project.linkLabels.repo, href: project.data.repoUrl },
      { label: ui.project.linkLabels.demo, href: project.data.demoUrl },
      { label: ui.project.linkLabels.paper, href: project.data.paperUrl },
      { label: ui.project.linkLabels.slides, href: project.data.slidesUrl }
    ]}
  />
  <div class="hero-actions" style="margin-top: 1rem;">
    <ProjectQuickPreview project={project} locale={locale} />
    <a class="button-link-secondary" href={href}>{ui.project.openCaseStudyLabel}</a>
  </div>
</article>
