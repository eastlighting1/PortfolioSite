---
import { getUiEntry } from "../../lib/content";
import ExternalLinks from "../common/ExternalLinks.astro";
import { type Locale } from "../../lib/i18n";

interface Props {
  project: any;
  index: number;
  locale?: Locale;
}

const { project, index, locale = "ko" } = Astro.props;
const uiEntry = await getUiEntry("labels", locale);
const ui = uiEntry.data;

const visibleLinks = [
  { label: ui.project.linkLabels.repo, href: project.data.repoUrl },
  { label: ui.project.linkLabels.demo, href: project.data.demoUrl },
  { label: ui.project.linkLabels.paper, href: project.data.paperUrl },
  { label: ui.project.linkLabels.slides, href: project.data.slidesUrl }
].filter((link) => link.href);
---

<section class="case-study case-study--sheet">
  <div class="case-study__eyebrow-row">
    <span class="small-label case-study__label">{ui.project.caseStudyLabelPrefix} {index + 1}</span>
    <span class="case-study__year-badge">{project.data.year}</span>
  </div>

  <div class="case-study__header">
    <div class="case-study__header-main">
      <h3 class="case-study__title">{project.data.title}</h3>
      <p class="case-study__dek">{project.data.summary}</p>
      <div class="case-study__meta-row">
        <span class="muted">{project.data.type}</span>
        <span class="separator">·</span>
        <span class="muted">{project.data.roles.join(", ")}</span>
      </div>
    </div>
  </div>

  <div class="case-study__body">
    <div class="case-study__main-content">
      <div class="case-study__grid">
        <section class="case-study__section case-study__section--problem">
          <h4>{ui.project.fieldLabels.problem}</h4>
          <div class="case-study__section-content">
            <p>{project.data.portfolioProblem ?? project.data.summary}</p>
          </div>
        </section>

        <section class="case-study__section case-study__section--approach">
          <h4>{ui.project.fieldLabels.approach}</h4>
          <div class="case-study__section-content">
            <p>{project.data.portfolioApproach ?? project.data.summary}</p>
          </div>
        </section>

        <section class="case-study__section case-study__section--outcome case-study__section--accent">
          <h4>{ui.project.fieldLabels.outcome}</h4>
          <div class="case-study__section-content">
            <div class="case-study__result-text">
              <p>{project.data.portfolioOutcome ?? project.data.summary}</p>
            </div>
            {project.data.metrics.length > 0 && (
              <div class="metric-row case-study__metrics-highlights">
                {project.data.metrics.map((metric: string) => (
                  <div class="metric-item">
                    <span class="metric-badge">{metric}</span>
                  </div>
                ))}
              </div>
            )}
          </div>
        </section>
      </div>
    </div>
  </div>

  <footer class="case-study__footer">
    <div class="case-study__footer-grid">
      {project.data.tags.length > 0 && (
        <div class="case-study__metadata-group">
          <span class="small-label">{locale === "ko" ? "기술 및 태그" : "Tech & Tags"}</span>
          <div class="tag-row">
            {project.data.tags.map((tag: string) => (
              <span class="tag-chip">{tag}</span>
            ))}
          </div>
        </div>
      )}

      {visibleLinks.length > 0 && (
        <div class="case-study__metadata-group">
          <span class="small-label">{locale === "ko" ? "증거 및 링크" : "Evidence & Links"}</span>
          <ExternalLinks locale={locale} links={visibleLinks} />
        </div>
      )}
    </div>
  </footer>
</section>
