---
import ProjectCard from "../projects/ProjectCard.astro";

interface Props {
  projects: any[];
  eyebrow: string;
  title: string;
  lead?: string;
}

const { projects, eyebrow, title, lead } = Astro.props;
---

<section class="section">
  <div class="container">
    <div class="eyebrow">{eyebrow}</div>
    <h2 class="section-title">{title}</h2>
    {lead && <p class="section-lead">{lead}</p>}
    <div class="preview-grid" style="margin-top: 2rem;">
      {projects.map((project, index) => (
        <ProjectCard project={project} dataReveal={`${(index % 4) + 1}`} />
      ))}
    </div>
  </div>
</section>
