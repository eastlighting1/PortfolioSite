---
import { withBase } from "../../data/site";
import { entrySlug } from "../../data/content";
import { localizePath, type Locale } from "../../data/i18n";

interface Props {
  research: any[];
  eyebrow: string;
  title: string;
  lead?: string;
  ctaLabel: string;
  locale?: Locale;
}

const { research, eyebrow, title, lead, ctaLabel, locale = "ko" } = Astro.props;
---

<section class="section">
  <div class="container">
    <div class="eyebrow">{eyebrow}</div>
    <h2 class="section-title">{title}</h2>
    {lead && <p class="section-lead">{lead}</p>}
    <div class="research-list" style="margin-top: 2rem;">
      {research.map((item, index) => (
        <article class="research-card" data-reveal={`${(index % 4) + 1}`}>
          <span class="small-label">{item.data.venue} | {item.data.year}</span>
          <h3>{item.data.title}</h3>
          <p class="muted">{item.data.abstract}</p>
          <div class="tag-row">
            {item.data.tags.slice(0, 4).map((tag: string) => (
              <span class="tag-chip">{tag}</span>
            ))}
          </div>
          <div style="margin-top: 1rem;">
            <a class="button-link-secondary" href={withBase(localizePath(`research/${entrySlug(item)}/`, locale))}>
              {ctaLabel}
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
