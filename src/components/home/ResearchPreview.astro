---
import { withBase } from "../../data/site";
import { entrySlug } from "../../data/content";

interface Props {
  research: any[];
}

const { research } = Astro.props;
---

<section class="section">
  <div class="container">
    <div class="eyebrow">Research Preview</div>
    <h2 class="section-title">Applied research and technical notes anchored in delivery concerns.</h2>
    <div class="research-list" style="margin-top: 2rem;">
      {research.map((item, index) => (
        <article class="research-card" data-reveal={`${(index % 4) + 1}`}>
          <span class="small-label">{item.data.venue} | {item.data.year}</span>
          <h3>{item.data.title}</h3>
          <p class="muted">{item.data.abstract}</p>
          <div class="tag-row">
            {item.data.tags.slice(0, 4).map((tag: string) => (
              <span class="tag-chip">{tag}</span>
            ))}
          </div>
          <div style="margin-top: 1rem;">
            <a class="button-link-secondary" href={withBase(`research/${entrySlug(item)}/`)}>Read Research</a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
