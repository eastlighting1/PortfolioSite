---
import { getGlobalEntry } from "../../data/content";
import { type Locale } from "../../data/i18n";

interface Props {
  eyebrow: string;
  title: string;
  locale?: Locale;
}

const { eyebrow, title, locale = "ko" } = Astro.props;
const profileEntry = await getGlobalEntry("profile", locale);
const profile = profileEntry.data;
---

<section class="section">
  <div class="container">
    <div class="eyebrow">{eyebrow}</div>
    <h2 class="section-title">{title}</h2>
    <div class="catalog-grid" style="margin-top: 2rem;">
      {profile.capabilityGroups.map((group, index) => (
        <article class="capability-card" data-reveal={`${(index % 4) + 1}`}>
          <h3>{group.title}</h3>
          <p class="muted">{group.description}</p>
          <div class="tag-row">
            {group.skills.map((skill) => (
              <span class="tag-chip">{skill}</span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
