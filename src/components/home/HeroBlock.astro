---
import { getGlobalEntry } from "../../data/content";
import { withBase } from "../../data/site";
import { localizePath, type Locale } from "../../data/i18n";

interface Props {
  eyebrow: string;
  summary: string;
  actions: {
    label: string;
    href: string;
    variant: "primary" | "secondary";
  }[];
  focusCard: {
    label: string;
    title: string;
    body: string;
    items: {
      label: string;
      value: string;
    }[];
  };
  locale?: Locale;
}

const { eyebrow, summary, actions, focusCard, locale = "ko" } = Astro.props;
const profileEntry = await getGlobalEntry("profile", locale);
const siteEntry = await getGlobalEntry("site", locale);
const profile = profileEntry.data;
const siteConfig = siteEntry.data;
---

<section class="section">
  <div class="container">
    <div class="hero-panel soft-card">
      <div>
        <div class="eyebrow" data-reveal="1">{eyebrow}</div>
        <h1 class="hero-title" data-reveal="2">{profile.name}</h1>
        <p class="hero-copy" data-reveal="3" set:html={summary} />
        <p class="hero-copy" data-reveal="4" set:html={profile.intro} />
        <div class="chip-row" data-reveal="4">
          <span class="role-chip">{siteConfig.primaryRole}</span>
          {siteConfig.secondaryRoles.map((role) => (
            <span class="role-chip">{role}</span>
          ))}
        </div>
        <div class="hero-actions" data-reveal="4">
          {actions.map((action) => (
            <a
              class={action.variant === "primary" ? "button-link" : "button-link-secondary"}
              href={withBase(localizePath(action.href, locale))}
            >
              {action.label}
            </a>
          ))}
        </div>
      </div>
      <div class="project-card">
        <span class="small-label">{focusCard.label}</span>
        <h2
          class="section-title focus-card__title"
          data-fit-title
          data-fit-max-lines="2"
          data-fit-min-rem="1.55"
          data-fit-max-rem="2.2"
          style="margin-top:0.6rem;"
          set:html={focusCard.title}
        />
        <p class="muted" set:html={focusCard.body} />
        <div class="compact-list">
          {focusCard.items.map((item) => (
            <div>
              <span class="small-label">{item.label}</span>
              <strong>{item.value}</strong>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  const setupFocusCardTitleFit = () => {
    const titles = document.querySelectorAll("[data-fit-title]");

    const fitTitle = (element) => {
      const maxLines = Number(element.dataset.fitMaxLines || "2");
      const minRem = Number(element.dataset.fitMinRem || "1.5");
      const maxRem = Number(element.dataset.fitMaxRem || "2.2");
      const rootFontSize = Number.parseFloat(getComputedStyle(document.documentElement).fontSize) || 16;
      const minPx = minRem * rootFontSize;
      const maxPx = maxRem * rootFontSize;

      const searchFontSize = (low, high, fits) => {
        let best = low;
        let left = low;
        let right = high;

        while (right - left > 0.5) {
          const mid = (left + right) / 2;
          element.style.fontSize = `${mid}px`;

          if (fits()) {
            best = mid;
            left = mid;
          } else {
            right = mid;
          }
        }

        return best;
      };

      const previousWhiteSpace = element.style.whiteSpace;
      const previousDisplay = element.style.display;
      const previousWebkitLineClamp = element.style.webkitLineClamp;
      const previousWebkitBoxOrient = element.style.webkitBoxOrient;
      const previousOverflow = element.style.overflow;

      element.style.display = "block";
      element.style.whiteSpace = "nowrap";
      const singleLineSize = searchFontSize(minPx, maxPx, () => element.scrollWidth <= element.clientWidth + 1);

      element.style.fontSize = `${singleLineSize}px`;
      const singleLineFits = element.scrollWidth <= element.clientWidth + 1;

      if (!singleLineFits) {
        element.style.whiteSpace = "normal";
        element.style.display = "-webkit-box";
        element.style.webkitBoxOrient = "vertical";
        element.style.webkitLineClamp = String(maxLines);
        element.style.overflow = "hidden";

        const multiLineSize = searchFontSize(minPx, maxPx, () => element.scrollHeight <= element.clientHeight + 1);
        element.style.fontSize = `${multiLineSize}px`;
      } else {
        element.style.display = "block";
        element.style.whiteSpace = "nowrap";
        element.style.webkitLineClamp = "";
        element.style.webkitBoxOrient = "";
        element.style.overflow = "visible";
      }

      if (previousDisplay && !element.style.display) {
        element.style.display = previousDisplay;
      }
      if (previousWhiteSpace && !element.style.whiteSpace) {
        element.style.whiteSpace = previousWhiteSpace;
      }
      if (previousWebkitLineClamp && !element.style.webkitLineClamp) {
        element.style.webkitLineClamp = previousWebkitLineClamp;
      }
      if (previousWebkitBoxOrient && !element.style.webkitBoxOrient) {
        element.style.webkitBoxOrient = previousWebkitBoxOrient;
      }
      if (previousOverflow && !element.style.overflow) {
        element.style.overflow = previousOverflow;
      }
    };

    titles.forEach((title) => fitTitle(title));

    if (window.__focusCardTitleResizeObserver) {
      window.__focusCardTitleResizeObserver.disconnect();
    }

    const observer = new ResizeObserver(() => {
      titles.forEach((title) => fitTitle(title));
    });

    titles.forEach((title) => {
      const card = title.closest(".project-card");
      observer.observe(card || title);
    });

    window.__focusCardTitleResizeObserver = observer;
  };

  setupFocusCardTitleFit();
  document.addEventListener("astro:page-load", setupFocusCardTitleFit);
</script>
