---
import { withBase } from "../../data/site";
import { localizePath, type Locale } from "../../data/i18n";

interface Props {
  eyebrow: string;
  title: string;
  cards: {
    label: string;
    title: string;
    body: string;
    href: string;
    ctaLabel: string;
  }[];
  locale?: Locale;
}

const { eyebrow, title, cards, locale = "ko" } = Astro.props;
---

<section class="section">
  <div class="container">
    <div class="eyebrow">{eyebrow}</div>
    <h2 class="section-title">{title}</h2>
    <div class="document-grid two-column" style="margin-top: 2rem;">
      {cards.map((card, index) => (
        <article class="document-card" data-reveal={`${index + 1}`}>
          <span class="small-label">{card.label}</span>
          <h3>{card.title}</h3>
          <p class="muted">{card.body}</p>
            <a class="button-link-secondary" href={withBase(localizePath(card.href, locale))}>{card.ctaLabel}</a>
          </article>
        ))}
    </div>
  </div>
</section>
