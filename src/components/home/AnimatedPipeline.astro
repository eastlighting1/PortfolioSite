---
import { getGlobalEntry } from "../../data/content";

interface Props {
  eyebrow: string;
  title: string;
  lead?: string;
}

const { eyebrow, title, lead } = Astro.props;
const profileEntry = await getGlobalEntry("profile");
const profile = profileEntry.data;
---

<section class="section">
  <div class="container">
    <div class="eyebrow">{eyebrow}</div>
    <h2 class="section-title">{title}</h2>
    {lead && <p class="section-lead">{lead}</p>}
    <div class="system-grid" style="margin-top: 2rem;">
      {profile.pipeline.map((stage, index) => (
        <article class="system-stage" data-reveal={`${(index % 4) + 1}`}>
          <span class="small-label">{stage.emphasis}</span>
          <h3>{stage.title}</h3>
          <p class="muted">{stage.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
