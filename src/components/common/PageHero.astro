---
interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  meta?: string[];
  className?: string;
}

const { eyebrow, title, description, meta = [], className = "" } = Astro.props;
---

<section class={`page-hero ${className}`.trim()} data-reveal="1">
  {eyebrow && <div class="eyebrow">{eyebrow}</div>}
  <h1 class="section-title">{title}</h1>
  <p class="section-lead">{description}</p>
  {meta.length > 0 && (
    <div class="meta-row">
      {meta.map((item) => (
        <span class="tag-chip">{item}</span>
      ))}
    </div>
  )}
</section>
