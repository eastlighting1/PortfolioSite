---
import { withBase } from "../../lib/site";
import { switchLocalePath, type Locale } from "../../lib/i18n";

interface Props {
  locale: Locale;
  pathname?: string;
}

const { locale, pathname = "/" } = Astro.props;
const koHref = withBase(switchLocalePath(pathname, "ko"));
const enHref = withBase(switchLocalePath(pathname, "en"));
---

<div class="locale-switch" aria-label="Language switcher">
  <a class={locale === "ko" ? "is-active" : undefined} href={koHref} aria-current={locale === "ko" ? "page" : undefined}>KO</a>
  <a class={locale === "en" ? "is-active" : undefined} href={enHref} aria-current={locale === "en" ? "page" : undefined}>EN</a>
</div>

<style>
.locale-switch {
  display: inline-flex;
  align-items: center;
  padding: 0.2rem;
  border: 1px solid var(--border);
  border-radius: 999px;
  background: var(--surface);
}

.locale-switch a {
  min-width: 2.4rem;
  padding: 0.35rem 0.7rem;
  border-radius: 999px;
  text-decoration: none;
  text-align: center;
  color: var(--text-soft);
  font-size: 0.85rem;
  font-weight: 600;
}

.locale-switch a.is-active {
  background: var(--ink);
  color: white;
}
</style>
