---
import { getGlobalEntry, getUiEntry } from "../../lib/content";
import { withBase } from "../../lib/site";
import { localizePath, type Locale } from "../../lib/i18n";
import LocaleSwitch from "./LocaleSwitch.astro";

interface Props {
  pathname?: string;
  locale?: Locale;
}

const { pathname = "/", locale = "ko" } = Astro.props;
const siteEntry = await getGlobalEntry("site", locale);
const linksEntry = await getGlobalEntry("links", locale);
const uiEntry = await getUiEntry("labels", locale);
const siteConfig = siteEntry.data;
const externalProfiles = linksEntry.data.externalProfiles;
const ui = uiEntry.data;

const normalize = (value: string) => (value.endsWith("/") ? value : `${value}/`);
const isActive = (currentPath: string, itemHref: string) => {
  const current = normalize(currentPath);
  const target = normalize(itemHref);
  if (target === "/") return current === "/";
  return current === target || current.startsWith(target);
};
---

<header class="site-header screen-only">
  <div class="container site-header__inner">
    <a class="site-brand" href={withBase(localizePath("/", locale))}>{siteConfig.name}</a>
    <nav class="site-nav site-nav--desktop" aria-label="Primary">
      {siteConfig.nav.map((item) => {
        const targetHref = localizePath(item.href, locale);
        const active = isActive(pathname, targetHref);
        return (
          <a href={withBase(targetHref)} aria-current={active ? "page" : undefined}>
            {item.label}
          </a>
        );
      })}
    </nav>
    <div class="header-utility">
      <div class="utility-links">
        {externalProfiles.slice(0, 2).map((link) => (
          <a href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
        ))}
      </div>
      <a href={withBase(localizePath("/resume/", locale))}>{ui.header.resumeButtonLabel}</a>
      <div class="header-locale">
        <LocaleSwitch locale={locale} pathname={pathname} />
      </div>
    </div>
    <details class="mobile-nav">
      <summary class="mobile-nav__toggle" aria-label={ui.header.mobileToggleLabel}>
        <span></span>
        <span></span>
        <span></span>
      </summary>
      <div class="mobile-nav__panel">
        <nav class="mobile-nav__links" aria-label="Mobile primary">
          {siteConfig.nav.map((item) => {
            const targetHref = localizePath(item.href, locale);
            const active = isActive(pathname, targetHref);
            return (
              <a href={withBase(targetHref)} aria-current={active ? "page" : undefined}>
                {item.label}
              </a>
            );
          })}
        </nav>
        <div class="mobile-nav__meta">
          <div class="mobile-nav__locale">
            <LocaleSwitch locale={locale} pathname={pathname} />
          </div>
          {externalProfiles.slice(0, 2).map((link) => (
            <a href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
          ))}
        </div>
      </div>
    </details>
  </div>
</header>


<style>
.site-header {
  position: sticky;
  top: 0;
  z-index: 20;
  background: rgba(249, 247, 241, 0.86);
  border-bottom: 1px solid rgba(215, 207, 191, 0.8);
  backdrop-filter: blur(16px);
}

.site-header__inner,
.site-footer__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  padding: 1rem 0;
}

.site-brand {
  font-family: var(--font-display);
  font-size: 1.2rem;
  font-weight: 700;
  text-decoration: none;
}

.site-nav,
.utility-links,
.inline-links,
.tag-row,
.chip-row,
.meta-row,
.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
}

.site-nav a,
.utility-links a,
.header-utility > a,
.inline-links a {
  text-decoration: none;
  color: var(--text-soft);
}

.site-nav a[aria-current="page"] {
  color: var(--text);
  font-weight: 600;
}

.header-utility {
  display: flex;
  align-items: center;
  gap: 1.1rem;
  margin-left: auto;
}

.header-locale {
  margin-left: 1rem;
}



.mobile-nav {
  display: none;
  position: relative;
  margin-left: auto;
}

.mobile-nav__toggle {
  display: inline-flex;
  flex-direction: column;
  justify-content: center;
  gap: 0.28rem;
  width: 3rem;
  height: 3rem;
  padding: 0.75rem;
  border: 1px solid var(--border);
  border-radius: 999px;
  background: var(--surface);
  cursor: pointer;
  list-style: none;
}

.mobile-nav__toggle::-webkit-details-marker {
  display: none;
}

.mobile-nav__toggle span {
  display: block;
  width: 100%;
  height: 2px;
  background: var(--ink);
  border-radius: 999px;
}

.mobile-nav__panel {
  position: absolute;
  right: 0;
  top: calc(100% + 0.75rem);
  width: min(20rem, calc(100vw - 2rem));
  padding: 1rem;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  background: rgba(255, 253, 248, 0.98);
  box-shadow: 0 24px 60px rgba(15, 23, 42, 0.16);
}

.mobile-nav__links,
.mobile-nav__meta {
  display: grid;
  gap: 0.55rem;
}

.mobile-nav__links a,
.mobile-nav__meta a {
  text-decoration: none;
  color: var(--text);
}

.mobile-nav__links a[aria-current="page"] {
  color: var(--accent-strong);
  font-weight: 700;
}

.mobile-nav__meta {
  margin-top: 0.85rem;
  padding-top: 0.85rem;
  border-top: 1px solid var(--surface-muted);
}

.mobile-nav__locale {
  justify-self: start;
  width: fit-content;
  max-width: 100%;
}

.mobile-nav__locale .locale-switch {
  display: flex;
  width: fit-content;
  max-width: 100%;
}

</style>
