---
import { getUiEntry } from "../../data/content";
import { type Locale } from "../../data/i18n";

interface LinkItem {
  label: string;
  href?: string;
}

interface Props {
  links: LinkItem[];
  locale?: Locale;
}

const { links, locale = "ko" } = Astro.props;
const visibleLinks = links.filter((link) => link.href);
const uiEntry = await getUiEntry("labels", locale);
const ui = uiEntry.data;
---

{visibleLinks.length > 0 && (
  <div class="external-links" aria-label={ui.externalLinksAriaLabel}>
    {visibleLinks.map((link) => (
      <a class="external-link" href={link.href} target="_blank" rel="noreferrer">
        {link.label}
      </a>
    ))}
  </div>
)}
