---
interface LinkItem {
  label: string;
  href?: string;
}

interface Props {
  links: LinkItem[];
}

const { links } = Astro.props;
const visibleLinks = links.filter((link) => link.href);
---

{visibleLinks.length > 0 && (
  <div class="external-links" aria-label="External links">
    {visibleLinks.map((link) => (
      <a class="external-link" href={link.href} target="_blank" rel="noreferrer">
        {link.label}
      </a>
    ))}
  </div>
)}
