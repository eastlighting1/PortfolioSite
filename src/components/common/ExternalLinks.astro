---
import { getUiEntry } from "../../lib/content";
import { type Locale } from "../../lib/i18n";
import SocialIcon from "./SocialIcon.astro";

interface LinkItem {
  label: string;
  href?: string;
}

interface Props {
  links: LinkItem[];
  locale?: Locale;
}

const { links, locale = "ko" } = Astro.props;
const visibleLinks = links.filter((link) => link.href);
const uiEntry = await getUiEntry("labels", locale);
const ui = uiEntry.data;
---

{visibleLinks.length > 0 && (
  <div class="external-links" aria-label={ui.externalLinksAriaLabel}>
    {visibleLinks.map((link) => (
      <a class="external-link" href={link.href} target="_blank" rel="noreferrer">
        <SocialIcon platform={link.label} size={15} />
        <span>{link.label}</span>
      </a>
    ))}
  </div>
)}

<style>
.external-link {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
}
</style>
