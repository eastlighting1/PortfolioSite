---
import { withBase } from "../../data/site";
import { entrySlug } from "../../data/content";

interface Props {
  item: any;
  dataReveal?: string;
}

const { item, dataReveal = "1" } = Astro.props;
---

<article class="research-card" data-reveal={dataReveal}>
  <span class="small-label">{item.data.venue} | {item.data.year}</span>
  <h3>{item.data.title}</h3>
  <details class="inline-expander inline-expander--compact">
    <summary>
      <span>Abstract Preview</span>
      <span class="inline-expander__hint">Expand</span>
    </summary>
    <p class="muted" style="margin-top: 0.85rem;">{item.data.abstract}</p>
  </details>
  <div class="meta-row">
    <span class="tag-chip">{item.data.type}</span>
  </div>
  <div class="tag-row" style="margin-top: 1rem;">
    {item.data.tags.map((tag: string) => (
      <span class="tag-chip">{tag}</span>
    ))}
  </div>
  <div style="margin-top: 1rem;">
    <a class="button-link-secondary" href={withBase(`research/${entrySlug(item)}/`)}>Open Detail</a>
  </div>
</article>
