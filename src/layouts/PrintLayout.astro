---
import { getGlobalEntry, getUiEntry } from "../lib/content";
import { toAbsoluteUrl, withBase } from "../lib/site";
import { localizePath, type Locale } from "../lib/i18n";
import LocaleSwitch from "../components/common/LocaleSwitch.astro";

interface Props {
  title: string;
  description?: string;
  pathname?: string;
  locale?: Locale;
  noindex?: boolean;
  openGraphType?: "website" | "article" | "profile";
}

const { title, pathname = "/", locale = "ko", noindex = false, openGraphType = "website" } = Astro.props;
const siteEntry = await getGlobalEntry("site", locale);
const uiEntry = await getUiEntry("labels", locale);
const siteConfig = siteEntry.data;
const ui = uiEntry.data;
const description = Astro.props.description ?? siteConfig.description;
const canonicalUrl = toAbsoluteUrl(siteConfig.siteUrl, pathname);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:type" content={openGraphType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" type="image/svg+xml" href={withBase("favicon.svg")} />
  </head>
  <body class="document-page">
    <main>
      <section class="section-tight">
        <div class="document-container">
          <div class="document-page__frame screen-only">
            <div class="document-page__masthead">
              <a class="site-brand" href={withBase(localizePath("/", locale))}>{siteConfig.name}</a>
              <div class="inline-links">
                {ui.printLayout.mastheadLinks.map((link) => (
                  <a href={withBase(localizePath(link.href, locale))}>{link.label}</a>
                ))}
              </div>
              <LocaleSwitch locale={locale} pathname={pathname} />
            </div>
          </div>
          <slot />
        </div>
      </section>
    </main>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
  @import "../styles/components.css";
  @import "../styles/portfolio.css";
  @import "../styles/motion.css";
  @import "../styles/print.css";
</style>
