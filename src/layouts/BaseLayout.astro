---
import SiteHeader from "../components/common/SiteHeader.astro";
import SiteFooter from "../components/common/SiteFooter.astro";
import { getGlobalEntry } from "../lib/content";
import { toAbsoluteUrl, withBase } from "../lib/site";
import { type Locale } from "../lib/i18n";
import { ViewTransitions } from "astro:transitions";

interface Props {
  title: string;
  description?: string;
  pathname?: string;
  locale?: Locale;
  noindex?: boolean;
  openGraphType?: "website" | "article" | "profile";
}

const { title, pathname = "/", locale = "ko", noindex = false, openGraphType = "website" } = Astro.props;
const siteEntry = await getGlobalEntry("site", locale);
const siteConfig = siteEntry.data;
const description = Astro.props.description ?? siteConfig.description;
const canonicalUrl = toAbsoluteUrl(siteConfig.siteUrl, pathname);
---

<!doctype html>
<html lang={locale} data-theme="paper">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <ViewTransitions />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:type" content={openGraphType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" type="image/svg+xml" href={withBase("favicon.svg")} />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="https://cdn.jsdelivr.net/gh/projectnoonnu/pretendard@1.0/Pretendard-Regular.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="https://cdn.jsdelivr.net/gh/projectnoonnu/pretendard@1.0/Pretendard-Bold.woff2" crossorigin />
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
  </head>
  <body>
    <div class="site-shell">
      <SiteHeader pathname={pathname} locale={locale} />
      <main>
        <slot />
      </main>
      <SiteFooter locale={locale} />
    </div>
    <script is:inline>
      let scrollObserver = null;
      const setupScrollReveal = () => {
        if (scrollObserver) {
          scrollObserver.disconnect();
          scrollObserver = null;
        }

        const items = document.querySelectorAll("[data-reveal]");
        if (!("IntersectionObserver" in window) || window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
          items.forEach((item) => item.classList.add("is-visible"));
          return;
        }

        scrollObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                scrollObserver.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.16, rootMargin: "0px 0px -8% 0px" }
        );

        items.forEach((item) => {
          item.classList.remove("is-visible");
          scrollObserver.observe(item);
        });
      };

      document.addEventListener("astro:page-load", setupScrollReveal);
      document.addEventListener("astro:before-swap", () => {
        if (scrollObserver) scrollObserver.disconnect();
      });
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
  @import "../styles/components.css";
  @import "../styles/portfolio.css";
  @import "../styles/motion.css";
  @import "../styles/print.css";
</style>
