---
import { getGlobalEntry, getUiEntry } from "../data/content";
import { withBase } from "../data/site";
import { localizePath, type Locale } from "../data/i18n";
import LocaleSwitch from "../components/common/LocaleSwitch.astro";

interface Props {
  title: string;
  description?: string;
  pathname?: string;
  locale?: Locale;
}

const { title, pathname = "/", locale = "ko" } = Astro.props;
const siteEntry = await getGlobalEntry("site", locale);
const uiEntry = await getUiEntry("labels", locale);
const siteConfig = siteEntry.data;
const ui = uiEntry.data;
const description = Astro.props.description ?? siteConfig.description;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={withBase("favicon.svg")} />
  </head>
  <body class="document-page">
    <main>
      <section class="section-tight">
        <div class="document-container">
          <div class="document-page__frame screen-only">
            <div class="document-page__masthead">
              <a class="site-brand" href={withBase(localizePath("/", locale))}>{siteConfig.name}</a>
              <div class="inline-links">
                {ui.documentLayout.mastheadLinks.map((link) => (
                  <a href={withBase(localizePath(link.href, locale))}>{link.label}</a>
                ))}
              </div>
              <LocaleSwitch locale={locale} pathname={pathname} />
            </div>
          </div>
          <slot />
        </div>
      </section>
    </main>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
  @import "../styles/components.css";
  @import "../styles/motion.css";
  @import "../styles/print.css";
</style>
