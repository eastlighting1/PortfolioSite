---
import ResearchDetailPage from "../../features/research/ResearchDetailPage.astro";
import { entrySlug } from "../../lib/content";
import { getResearchStaticPaths } from "../../features/research/paths";

const locale = "ko" as const;

export async function getStaticPaths() {
  return getResearchStaticPaths("ko");
}

const { item } = Astro.props;
---

<ResearchDetailPage locale={locale} pathname={`/research/${entrySlug(item)}/`} item={item} />
