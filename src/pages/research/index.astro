---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/common/PageHero.astro";
import ResearchList from "../../components/research/ResearchList.astro";
import { getPageEntry } from "../../data/content";

const researchPage = await getPageEntry("research");
if (researchPage.data.pageType !== "research") {
  throw new Error("Missing research page content configuration.");
}

const research = (await getCollection("research")).sort((a, b) => b.data.year - a.data.year);
const heroMeta = [`${research.length} entries`, ...researchPage.data.hero.meta];
---

<BaseLayout
  title={researchPage.data.documentTitle}
  description={researchPage.data.documentDescription}
  pathname="/research/"
>
  <section class="section">
    <div class="container">
      <PageHero
        className={researchPage.data.hero.className}
        eyebrow={researchPage.data.hero.eyebrow}
        title={researchPage.data.hero.title}
        description={researchPage.data.hero.description}
        meta={heroMeta}
      />
      <div class="section-tight">
        <ResearchList research={research} />
      </div>
    </div>
  </section>
</BaseLayout>
