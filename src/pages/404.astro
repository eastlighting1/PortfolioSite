---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPageEntry } from "../data/content";
import { withBase } from "../data/site";

const notFoundPage = await getPageEntry("not-found");
if (notFoundPage.data.pageType !== "not-found") {
  throw new Error("Missing not-found page content configuration.");
}
---

<BaseLayout title={notFoundPage.data.documentTitle} description={notFoundPage.data.documentDescription} pathname="/404/">
  <section class="section">
    <div class="container">
      <div class="page-hero">
        <div class="eyebrow">{notFoundPage.data.hero.eyebrow}</div>
        <h1 class="section-title">{notFoundPage.data.hero.title}</h1>
        <p class="section-lead">{notFoundPage.data.hero.description}</p>
        <div class="hero-actions" style="margin-top: 1rem;">
          {notFoundPage.data.hero.actions.map((action) => (
            <a
              class={action.variant === "primary" ? "button-link" : "button-link-secondary"}
              href={withBase(action.href)}
            >
              {action.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
