---
import ProjectDetailPage from "../../features/projects/ProjectDetailPage.astro";
import { entrySlug } from "../../lib/content";
import { getProjectStaticPaths } from "../../features/projects/paths";

const locale = "ko" as const;

export async function getStaticPaths() {
  return getProjectStaticPaths("ko");
}

const { project } = Astro.props;
---

<ProjectDetailPage locale={locale} pathname={`/projects/${entrySlug(project)}/`} project={project} />
