---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/common/PageHero.astro";
import ProjectGrid from "../../components/projects/ProjectGrid.astro";

const projects = (await getCollection("projects")).sort((a, b) => b.data.year - a.data.year);
---

<BaseLayout
  title="Projects | Eunseok Lee"
  description="Project catalogue covering data systems, applied research, and production ML delivery."
  pathname="/projects/"
>
  <section class="section">
    <div class="container">
      <PageHero
        eyebrow="Projects"
        title="Project catalogue"
        description="A dedicated catalogue of applied ML, data platform, and delivery work. Filtering can be added later, but the information architecture is already split into clear project detail pages."
        meta={[`${projects.length} projects`, "Case-study format", "External links supported"]}
      />
      <div class="section-tight">
        <ProjectGrid projects={projects} />
      </div>
    </div>
  </section>
</BaseLayout>
