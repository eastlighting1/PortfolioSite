---
import { getCollection } from "astro:content";
import DocumentLayout from "../layouts/DocumentLayout.astro";
import PrintToolbar from "../components/document/PrintToolbar.astro";
import ResumeHeader from "../components/document/ResumeHeader.astro";
import ResumeSection from "../components/document/ResumeSection.astro";
import { getGlobalEntry, getLocalizedCollection, getPageEntry } from "../data/content";

const locale = "ko" as const;

const resumePage = await getPageEntry("resume", locale);
const profileEntry = await getGlobalEntry("profile", locale);
const experienceEntry = await getGlobalEntry("experience", locale);
const educationEntry = await getGlobalEntry("education", locale);
const profile = profileEntry.data;
const experience = experienceEntry.data.items;
const education = educationEntry.data.items;

if (resumePage.data.pageType !== "resume") {
  throw new Error("Missing resume page content configuration.");
}

const selectedProjects = (await getLocalizedCollection("projects", locale))
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, resumePage.data.sections.projects.count ?? 2);

const selectedResearch = (await getLocalizedCollection("research", locale))
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, resumePage.data.sections.research.count ?? 1);

const featuredExperience = experience.slice(0, resumePage.data.sections.experience.count ?? 2);
---

<DocumentLayout
  title={resumePage.data.documentTitle}
  description={resumePage.data.documentDescription}
  pathname="/resume/"
  locale={locale}
>
  <PrintToolbar label={resumePage.data.printToolbarLabel} locale={locale} />
  <div class="paper-sheet paper-sheet--resume document-shell">
    <ResumeHeader locale={locale} />
    <div class="resume-compact-grid">
      <div class="document-list">
        {resumePage.data.layout.leftColumn.map((sectionId) => {
          if (sectionId === "summary" && resumePage.data.sections.summary.enabled) {
            return (
              <ResumeSection title={resumePage.data.sections.summary.title} className="resume-section--summary">
                <p>{profile.summary}</p>
              </ResumeSection>
            );
          }
          if (sectionId === "experience" && resumePage.data.sections.experience.enabled) {
            return (
              <ResumeSection title={resumePage.data.sections.experience.title} className="resume-section--experience">
                {featuredExperience.map((item) => (
                  <div class="resume-item resume-item--tight">
                    <strong>{item.role}</strong>
                    <div class="muted">{item.organization} | {item.period}</div>
                    <ul class="compact-bullets">
                      {item.bullets.map((bullet) => (
                        <li>{bullet}</li>
                      ))}
                    </ul>
                  </div>
                ))}
              </ResumeSection>
            );
          }
          if (sectionId === "projects" && resumePage.data.sections.projects.enabled) {
            return (
              <ResumeSection title={resumePage.data.sections.projects.title} className="resume-section--projects">
                {selectedProjects.map((project) => (
                  <div class="resume-item resume-item--tight">
                    <strong>{project.data.title}</strong>
                    <div class="muted">{project.data.type} | {project.data.year}</div>
                    <p>{project.data.summary}</p>
                  </div>
                ))}
              </ResumeSection>
            );
          }
          return null;
        })}
      </div>
      <div class="document-list">
        {resumePage.data.layout.rightColumn.map((sectionId) => {
          if (sectionId === "skills" && resumePage.data.sections.skills.enabled) {
            return (
              <ResumeSection title={resumePage.data.sections.skills.title} className="resume-section--skills">
                <div class="compact-skill-grid">
                  {profile.capabilityGroups.map((group) => (
                    <div class="resume-item resume-item--tight">
                      <strong>{group.title}</strong>
                      <p class="muted">{group.skills.join(" | ")}</p>
                    </div>
                  ))}
                </div>
              </ResumeSection>
            );
          }
          if (sectionId === "research" && resumePage.data.sections.research.enabled) {
            return (
              <ResumeSection title={resumePage.data.sections.research.title} className="resume-section--research">
                {selectedResearch.map((item) => (
                  <div class="resume-item resume-item--tight">
                    <strong>{item.data.title}</strong>
                    <div class="muted">{item.data.venue} | {item.data.year}</div>
                    <p>{item.data.abstract}</p>
                  </div>
                ))}
              </ResumeSection>
            );
          }
          if (sectionId === "education" && resumePage.data.sections.education.enabled) {
            return (
              <ResumeSection title={resumePage.data.sections.education.title} className="resume-section--education">
                {education.map((item) => (
                  <div class="resume-item resume-item--tight">
                    <strong>{item.degree}</strong>
                    <div class="muted">{item.school} | {item.period}</div>
                    <p>{item.detail}</p>
                  </div>
                ))}
              </ResumeSection>
            );
          }
          return null;
        })}
      </div>
    </div>
  </div>
</DocumentLayout>
