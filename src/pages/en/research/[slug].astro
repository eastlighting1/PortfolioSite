---
import ResearchDetailPage from "../../../features/research/ResearchDetailPage.astro";
import { entrySlug } from "../../../lib/content";
import { getResearchStaticPaths } from "../../../features/research/paths";

const locale = "en" as const;

export async function getStaticPaths() {
  return getResearchStaticPaths("en");
}

const { item } = Astro.props;
---

<ResearchDetailPage locale={locale} pathname={`/en/research/${entrySlug(item)}/`} item={item} />
