---
import ProjectDetailPage from "../../../features/projects/ProjectDetailPage.astro";
import { entrySlug } from "../../../lib/content";
import { getProjectStaticPaths } from "../../../features/projects/paths";

const locale = "en" as const;

export async function getStaticPaths() {
  return getProjectStaticPaths("en");
}

const { project } = Astro.props;
---

<ProjectDetailPage locale={locale} pathname={`/en/projects/${entrySlug(project)}/`} project={project} />
