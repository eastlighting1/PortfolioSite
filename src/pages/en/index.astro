---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HeroBlock from "../../components/home/HeroBlock.astro";
import AnimatedPipeline from "../../components/home/AnimatedPipeline.astro";
import FeaturedProjects from "../../components/home/FeaturedProjects.astro";
import ResearchPreview from "../../components/home/ResearchPreview.astro";
import ExperienceSnapshot from "../../components/home/ExperienceSnapshot.astro";
import CapabilityMap from "../../components/home/CapabilityMap.astro";
import DocumentCTA from "../../components/home/DocumentCTA.astro";
import { getGlobalEntry, getLocalizedCollection, getPageEntry } from "../../data/content";

const locale = "en" as const;
const homePage = await getPageEntry("home", locale);
const siteEntry = await getGlobalEntry("site", locale);
const siteConfig = siteEntry.data;

if (homePage.data.pageType !== "home") {
  throw new Error("Missing home page content configuration.");
}

const projects = (await getLocalizedCollection("projects", locale))
  .sort((a, b) => b.data.year - a.data.year)
  .filter((project) => project.data.featured)
  .slice(0, homePage.data.featuredProjects.count);

const research = (await getLocalizedCollection("research", locale))
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, homePage.data.researchPreview.count);
---

<BaseLayout title={siteConfig.title} description={siteConfig.description} pathname="/en/" locale={locale}>
  {homePage.data.sectionOrder.map((sectionId) => {
    if (sectionId === "hero" && homePage.data.hero.enabled) {
      return <HeroBlock {...homePage.data.hero} locale={locale} />;
    }
    if (sectionId === "pipeline" && homePage.data.pipeline.enabled) {
      return <AnimatedPipeline {...homePage.data.pipeline} locale={locale} />;
    }
    if (sectionId === "featuredProjects" && homePage.data.featuredProjects.enabled) {
      return (
        <FeaturedProjects
          projects={projects}
          locale={locale}
          eyebrow={homePage.data.featuredProjects.eyebrow}
          title={homePage.data.featuredProjects.title}
          lead={homePage.data.featuredProjects.lead}
        />
      );
    }
    if (sectionId === "researchPreview" && homePage.data.researchPreview.enabled) {
      return (
        <ResearchPreview
          research={research}
          locale={locale}
          eyebrow={homePage.data.researchPreview.eyebrow}
          title={homePage.data.researchPreview.title}
          lead={homePage.data.researchPreview.lead}
          ctaLabel={homePage.data.researchPreview.ctaLabel}
        />
      );
    }
    if (sectionId === "experienceSnapshot" && homePage.data.experienceSnapshot.enabled) {
      return (
        <ExperienceSnapshot
          eyebrow={homePage.data.experienceSnapshot.eyebrow}
          title={homePage.data.experienceSnapshot.title}
          ctaLabel={homePage.data.experienceSnapshot.ctaLabel}
          count={homePage.data.experienceSnapshot.count}
          locale={locale}
        />
      );
    }
    if (sectionId === "capabilityMap" && homePage.data.capabilityMap.enabled) {
      return (
        <CapabilityMap
          eyebrow={homePage.data.capabilityMap.eyebrow}
          title={homePage.data.capabilityMap.title}
          locale={locale}
        />
      );
    }
    if (sectionId === "documents" && homePage.data.documents.enabled) {
      return (
        <DocumentCTA
          eyebrow={homePage.data.documents.eyebrow}
          title={homePage.data.documents.title}
          cards={homePage.data.documents.cards}
          locale={locale}
        />
      );
    }
    return null;
  })}
</BaseLayout>
