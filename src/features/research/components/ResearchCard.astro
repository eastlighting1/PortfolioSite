---
import { entrySlug, getUiEntry } from "../../../lib/content";
import { withBase } from "../../../lib/site";
import { localizePath, type Locale } from "../../../lib/i18n";

interface Props {
  item: any;
  dataReveal?: string;
  locale?: Locale;
}

const { item, dataReveal = "1", locale = "ko" } = Astro.props;
const slug = entrySlug(item);
const href = withBase(localizePath(`research/${slug}/`, locale));
const uiEntry = await getUiEntry("labels", locale);
const ui = uiEntry.data;
const tags = item.data.tags ?? [];
const visibleTags = tags.slice(0, 2);
const hiddenTagCount = Math.max(0, tags.length - visibleTags.length);
const normalizedType = String(item.data.type ?? "").toLowerCase();
const researchVariant = normalizedType.includes("journal") || normalizedType.includes("저널")
  ? "journal"
  : normalizedType.includes("conference") || normalizedType.includes("학회")
    ? "conference"
    : normalizedType.includes("technical") || normalizedType.includes("기술")
      ? "technical"
      : "other";
const isTechnicalNote = slug === "multimodal-evaluation-note" || researchVariant === "technical";
const ctaLabel = isTechnicalNote
  ? locale === "ko"
    ? "노트 보기"
    : "Open Note"
  : ui.research.openDetailLabel;
const keywordsLabel = locale === "ko" ? "핵심 키워드" : "Keywords";
const summary = item.data.abstract.split(/(?<=[.!?])\s+/)[0] ?? item.data.abstract;
---

<article
  class:list={[
    "research-card",
    isTechnicalNote && "research-card--note",
    `research-card--${researchVariant}`
  ]}
  data-reveal={dataReveal}
>
  <div class="research-card__topline">
    <span class="research-card__type-badge">{item.data.type}</span>
    <span class="research-card__year">{item.data.year}</span>
  </div>
  <div class="research-card__header">
    <p class="research-card__venue">{item.data.venue}</p>
    <h3>{item.data.title}</h3>
  </div>
  <p class="muted research-card__summary">{summary}</p>
  {visibleTags.length > 0 && (
    <div class="research-card__keywords" style="margin-top: auto;">
      <span class="small-label">{keywordsLabel}</span>
      <div class="tag-row research-card__tag-row">
        {visibleTags.map((tag: string) => (
          <span class="tag-chip">{tag}</span>
        ))}
        {hiddenTagCount > 0 && <span class="tag-chip tag-chip--muted">+{hiddenTagCount}</span>}
      </div>
    </div>
  )}
  <div class="research-card__footer">
    <a class="button-link-secondary" href={href}>{ctaLabel}</a>
  </div>
</article>
