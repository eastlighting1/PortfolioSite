---
import { getUiEntry } from "../../../lib/content";
import ExternalLinks from "../../../components/common/ExternalLinks.astro";
import { type Locale } from "../../../lib/i18n";

interface Props {
  item: any;
  locale?: Locale;
}

const { item, locale = "ko" } = Astro.props;
const uiEntry = await getUiEntry("labels", locale);
const ui = uiEntry.data;
---

<section class="detail-hero" data-reveal="1">
  <div class="eyebrow">{ui.research.detailEyebrow}</div>
  <h1 class="section-title">{item.data.title}</h1>
  <p class="section-lead">{item.data.abstract}</p>
  <div class="meta-list">
    <div class="meta-item">
      <span>{ui.research.fieldLabels.venue}</span>
      <span>{item.data.venue}</span>
    </div>
    <div class="meta-item">
      <span>{ui.research.fieldLabels.year}</span>
      <span>{item.data.year}</span>
    </div>
    <div class="meta-item">
      <span>{ui.research.fieldLabels.type}</span>
      <span>{item.data.type}</span>
    </div>
  </div>
  <div class="tag-row" style="margin-top: 1rem;">
    {item.data.tags.map((tag: string) => (
      <span class="tag-chip">{tag}</span>
    ))}
  </div>
  <ExternalLinks
    locale={locale}
    links={[
      { label: ui.research.linkLabels.pdf, href: item.data.pdfUrl },
      { label: ui.research.linkLabels.repo, href: item.data.repoUrl },
      { label: ui.research.linkLabels.slides, href: item.data.slidesUrl }
    ]}
  />
</section>
