---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/common/PageHero.astro";
import { getGlobalEntry, getPageEntry } from "../../lib/content";
import { localizePath, type Locale } from "../../lib/i18n";
import { withBase } from "../../lib/site";

interface Props {
  locale: Locale;
  pathname: string;
}

const { locale, pathname } = Astro.props;
const contactPage = await getPageEntry("contact", locale);
const siteEntry = await getGlobalEntry("site", locale);
const linksEntry = await getGlobalEntry("links", locale);
const siteConfig = siteEntry.data;
const externalProfiles = linksEntry.data.externalProfiles;

if (contactPage.data.pageType !== "contact") {
  throw new Error("Missing contact page content configuration.");
}

const resolveHref = (href?: string) => {
  if (!href) return undefined;
  if (href.startsWith("http") || href.startsWith("mailto:") || href.startsWith("#")) return href;
  return withBase(localizePath(href, locale));
};
---

<BaseLayout title={contactPage.data.documentTitle} description={contactPage.data.documentDescription} pathname={pathname} locale={locale}>
  {contactPage.data.sectionOrder.map((sectionId) => {
    if (sectionId === "hero") {
      return (
        <section class="section contact-hero-section">
          <div class="container">
            <PageHero
              eyebrow={contactPage.data.hero.eyebrow}
              title={contactPage.data.hero.title}
              description={contactPage.data.hero.description}
            />
          </div>
        </section>
      );
    }

    if (sectionId === "intents" && contactPage.data.intents.enabled) {
      return (
        <section class="section-tight">
          <div class="container">
            <div class="section-head">
              <div class="eyebrow">{contactPage.data.intents.eyebrow}</div>
              <h2 class="section-title">{contactPage.data.intents.title}</h2>
              {contactPage.data.intents.lead && <p class="section-lead">{contactPage.data.intents.lead}</p>}
            </div>
            <div class="contact-intent-grid">
              {contactPage.data.intents.cards.map((intent) => (
                <article class="contact-card contact-card--intent">
                  {intent.label && <span class="small-label">{intent.label}</span>}
                  <h3>{intent.title}</h3>
                  <p class="muted">{intent.body}</p>
                  {intent.href && intent.ctaLabel && (
                    <a class="button-link-secondary" href={resolveHref(intent.href)}>{intent.ctaLabel}</a>
                  )}
                </article>
              ))}
            </div>
          </div>
        </section>
      );
    }

    if (sectionId === "response" && contactPage.data.response.enabled) {
      return (
        <section class="section-tight">
          <div class="container">
            <div class="contact-response-panel">
              <span class="small-label">{contactPage.data.response.title}</span>
              <p>{contactPage.data.response.body}</p>
            </div>
          </div>
        </section>
      );
    }

    if (sectionId === "links") {
      return (
        <section class="section-tight">
          <div class="container">
            <div class="section-head">
              <div class="eyebrow">{contactPage.data.cards.title}</div>
              {contactPage.data.cards.lead && <p class="section-lead">{contactPage.data.cards.lead}</p>}
            </div>
            <div class="contact-grid three-column">
              <article class="contact-card contact-card--primary">
                <span class="small-label">{contactPage.data.cards.emailLabel}</span>
                <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
              </article>
              {externalProfiles.map((link) => (
                <article class="contact-card">
                  <span class="small-label">{link.label}</span>
                  <a href={link.href} target="_blank" rel="noreferrer">
                    {contactPage.data.cards.externalValueMode === "label" ? link.label : link.href}
                  </a>
                </article>
              ))}
            </div>
          </div>
        </section>
      );
    }

    return null;
  })}
</BaseLayout>
