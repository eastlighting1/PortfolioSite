---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/common/PageHero.astro";
import { getGlobalEntry, getPageEntry } from "../../lib/content";
import { type Locale } from "../../lib/i18n";

interface Props {
  locale: Locale;
  pathname: string;
}

const { locale, pathname } = Astro.props;
const contactPage = await getPageEntry("contact", locale);
const siteEntry = await getGlobalEntry("site", locale);
const linksEntry = await getGlobalEntry("links", locale);
const siteConfig = siteEntry.data;
const externalProfiles = linksEntry.data.externalProfiles;
const contactIntents =
  locale === "ko"
    ? [
        {
          title: "채용 및 역할 제안",
          body: "응용 AI, MLOps, 의료 AI, 또는 연구와 구현을 함께 다루는 역할에 대한 대화를 환영합니다."
        },
        {
          title: "연구 및 기술 협업",
          body: "대화형 AI, 의료 AI, 평가 중심 시스템, 재현 가능한 실험 환경에 대한 협업 제안을 열어두고 있습니다."
        },
        {
          title: "포트폴리오 및 프로젝트 대화",
          body: "프로젝트 구조, 사례 정리 방식, 기술 선택에 대한 피드백이나 대화도 편하게 보낼 수 있습니다."
        }
      ]
    : [
        {
          title: "Hiring and Role Opportunities",
          body: "I am open to conversations about applied AI, MLOps, healthcare AI, and roles that connect research with implementation."
        },
        {
          title: "Research and Technical Collaboration",
          body: "I welcome collaboration around conversational AI, healthcare AI, evaluation-focused systems, and reproducible experimentation."
        },
        {
          title: "Portfolio and Project Conversation",
          body: "Feedback or conversation about project structure, technical choices, and case-study communication is also welcome."
        }
      ];
const responseNote =
  locale === "ko"
    ? "가장 빠른 연락 방법은 이메일이며, GitHub, LinkedIn, Google Scholar에서도 작업 맥락을 바로 확인할 수 있습니다."
    : "Email is the fastest way to reach me, and GitHub, LinkedIn, and Google Scholar provide the quickest context on my work.";

if (contactPage.data.pageType !== "contact") {
  throw new Error("Missing contact page content configuration.");
}
---

<BaseLayout title={contactPage.data.documentTitle} description={contactPage.data.documentDescription} pathname={pathname} locale={locale}>
  <section class="section">
    <div class="container">
      <PageHero
        eyebrow={contactPage.data.hero.eyebrow}
        title={contactPage.data.hero.title}
        description={contactPage.data.hero.description}
      />
      <div class="contact-intent-grid section-tight">
        {contactIntents.map((intent) => (
          <article class="contact-card contact-card--intent">
            <h2>{intent.title}</h2>
            <p class="muted">{intent.body}</p>
          </article>
        ))}
      </div>
      <p class="section-lead">{responseNote}</p>
      <div class="contact-grid three-column section-tight">
        <article class="contact-card">
          <span class="small-label">{contactPage.data.cards.emailLabel}</span>
          <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
        </article>
        {externalProfiles.map((link) => (
          <article class="contact-card">
            <span class="small-label">{link.label}</span>
            <a href={link.href} target="_blank" rel="noreferrer">
              {contactPage.data.cards.externalValueMode === "label" ? link.label : link.href}
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
