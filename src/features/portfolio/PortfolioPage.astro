        {printRecognitionEntries.length > 0 && (
          <section class="portfolio-print-dump__section">
            <h2>{recognitionPage?.title ?? (locale === "ko" ? "수료와 수상" : "Certificates & Awards")}</h2>
            <div class="portfolio-print-dump__recognition-grid">
              {printRecognitionEntries.map((entry) => (
                <article class="portfolio-print-dump__recognition-card">
