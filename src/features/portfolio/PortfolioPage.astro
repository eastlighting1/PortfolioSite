---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { entrySlug, getGlobalEntry, getLocalizedCollection, getPageEntry } from "../../lib/content";
import { localizePath, type Locale } from "../../lib/i18n";
import { withBase } from "../../lib/site";
import { buildPortfolioViewModel } from "./portfolio-data";
import ContactPanel from "./components/ContactPanel.astro";
import FeaturedCaseCard from "./components/FeaturedCaseCard.astro";
import EvidenceLibrary from "./components/EvidenceLibrary.astro";
import OutcomeMetricGrid from "./components/OutcomeMetricGrid.astro";
import PortfolioHero from "./components/PortfolioHero.astro";
import PortfolioSectionHead from "./components/PortfolioSectionHead.astro";
import PortfolioSectionNav from "./components/PortfolioSectionNav.astro";
import ProcessGrid from "./components/ProcessGrid.astro";
import RecognitionGrid from "./components/RecognitionGrid.astro";
import ResearchBridge from "./components/ResearchBridge.astro";
import ValueMap from "./components/ValueMap.astro";

interface Props {
  locale: Locale;
  pathname: string;
}

const { locale, pathname } = Astro.props;

const portfolioPage = await getPageEntry("portfolio", locale);
const profileEntry = await getGlobalEntry("profile", locale);
const siteEntry = await getGlobalEntry("site", locale);
const linksEntry = await getGlobalEntry("links", locale);
const recognitionEntry = await getGlobalEntry("recognition", locale);

const profile = profileEntry.data;
const siteConfig = siteEntry.data;
const links = linksEntry.data;
const recognition = recognitionEntry.data;

if (portfolioPage.data.pageType !== "portfolio") {
  throw new Error("Missing portfolio page content configuration.");
}

const allProjects = (await getLocalizedCollection("projects", locale))
  .sort((a, b) => b.data.year - a.data.year)
  .map((project) => ({ ...project, slug: entrySlug(project) }));
const allResearch = (await getLocalizedCollection("research", locale))
  .sort((a, b) => b.data.year - a.data.year);

const {
  hero,
  roleThemes,
  aidlcStages,
  evidenceGroups,
  featuredCases,
  portfolioMetrics,
  recognitionEntries,
  researchLinks,
  navigation,
  contactItems,
  process,
  valueItems,
  labels
} = buildPortfolioViewModel({
  locale,
  profile,
  siteConfig,
  links,
  recognition,
  portfolioPage,
  allProjects,
  allResearch
});

const resolveHref = (href: string) => {
  if (href.startsWith("#") || href.startsWith("http") || href.startsWith("mailto:")) return href;
  return withBase(localizePath(href, locale));
};

const localizedProjectsHref = withBase(localizePath("/projects/", locale));
const localizedResumeHref = withBase(localizePath("/resume/", locale));
const resolvedHero = {
  ...hero,
  actions: hero.actions.map((action: { label: string; href: string; variant: "primary" | "secondary" }) => ({
    ...action,
    href: resolveHref(action.href)
  }))
};
const sectionHeadings = portfolioPage.data.sectionHeadings ?? {};
const getSectionHeading = (id: string, fallbackTitle: string) => ({
  eyebrow: sectionHeadings[id]?.eyebrow ?? labels[id] ?? id,
  title: sectionHeadings[id]?.title ?? fallbackTitle,
  lead: sectionHeadings[id]?.lead
});
---

<BaseLayout
  title={portfolioPage.data.documentTitle}
  description={portfolioPage.data.documentDescription}
  pathname={pathname}
  locale={locale}
>
  <section class="portfolio-showcase">
    <PortfolioSectionNav
      items={navigation}
      ariaLabel={locale === "ko" ? "포트폴리오 섹션" : "Portfolio sections"}
    />

    <PortfolioHero
      hero={resolvedHero}
      evidenceCases={featuredCases}
      evidenceLabel={locale === "ko" ? "핵심 증거" : "Key evidence"}
    />

    {portfolioPage.data.sections.map((sectionId) => {
      if (sectionId === "valueMap") {
        const heading = getSectionHeading("valueMap", locale === "ko" ? "세 개의 역할이 같은 무게로 검토됩니다" : "Three role themes carry equal review weight");
        return (
          <section id="valueMap" class="portfolio-band portfolio-band--value">
            <PortfolioSectionHead {...heading} />
            <ValueMap items={roleThemes} />
          </section>
        );
      }

      if (sectionId === "aidlc") {
        const heading = getSectionHeading("aidlc", locale === "ko" ? "AI-Driven Development Life Cycle로 작업 흐름을 설명합니다" : "AI-Driven Development Life Cycle as the operating model");
        return (
          <section id="aidlc" class="portfolio-band">
            <PortfolioSectionHead {...heading} />
            <ProcessGrid items={aidlcStages} />
          </section>
        );
      }

      if (sectionId === "evidenceLibrary") {
        const heading = getSectionHeading("evidenceLibrary", locale === "ko" ? "프로젝트는 역할별 증거로 읽힙니다" : "Projects are organized as role-based evidence");
        return (
          <section id="evidenceLibrary" class="portfolio-band portfolio-band--evidence">
            <PortfolioSectionHead {...heading} />
            <EvidenceLibrary groups={evidenceGroups} labels={labels} locale={locale} />
          </section>
        );
      }

      if (sectionId === "outcomes" && portfolioMetrics.length > 0) {
        const heading = getSectionHeading("outcomes", locale === "ko" ? "주요 성과는 맥락과 함께 제시합니다" : "Outcomes stay close to their evidence");
        return (
          <section id="outcomes" class="portfolio-band">
            <PortfolioSectionHead {...heading} />
            <OutcomeMetricGrid metrics={portfolioMetrics} />
          </section>
        );
      }

      if (sectionId === "featuredCases") {
        const heading = getSectionHeading("featuredCases", locale === "ko" ? "문제, 결정, 결과가 함께 보이는 대표 작업" : "Featured work framed by problem, decision, and outcome");
        return (
          <section id="featuredCases" class="portfolio-band portfolio-band--cases">
            <PortfolioSectionHead {...heading} />
            <div class="portfolio-case-stack">
              {featuredCases.map((item, index) => (
                <FeaturedCaseCard item={item} labels={labels} locale={locale} featured={index === 0} />
              ))}
            </div>
          </section>
        );
      }

      if (sectionId === "process") {
        const heading = getSectionHeading("process", locale === "ko" ? "반복 가능한 작업 방식" : "A repeatable way of turning research into systems");
        return (
          <section id="process" class="portfolio-band">
            <PortfolioSectionHead {...heading} />
            <ProcessGrid items={process} />
          </section>
        );
      }

      if (sectionId === "researchBridge") {
        const heading = getSectionHeading("researchBridge", locale === "ko" ? "연구는 별도 선반이 아니라 구현의 근거입니다" : "Research is evidence that feeds implementation");
        return (
          <section id="researchBridge" class="portfolio-band portfolio-band--research">
            <PortfolioSectionHead {...heading} />
            <ResearchBridge items={researchLinks} />
          </section>
        );
      }

      if (sectionId === "recognition" && recognitionEntries.length > 0) {
        const heading = getSectionHeading("recognition", locale === "ko" ? "학습과 실무 기반을 보강한 이력" : "Learning and practice signals behind the work");
        return (
          <section id="recognition" class="portfolio-band">
            <PortfolioSectionHead {...heading} />
            <RecognitionGrid entries={recognitionEntries} locale={locale} />
          </section>
        );
      }

      if (sectionId === "contact") {
        return (
          <section id="contact" class="portfolio-band portfolio-band--contact">
            <ContactPanel
              labels={labels}
              locale={locale}
              profile={profile}
              resumeHref={localizedResumeHref}
              projectsHref={localizedProjectsHref}
              contactItems={contactItems}
            />
          </section>
        );
      }

      return null;
    })}
  </section>
</BaseLayout>
