                        : labels.certificate
                      : recognitionPage?.kind === "recognition"
                        ? recognitionPage.awardTitle
                        : labels.award}
                  </p>
                  <h3>{entry.item.title}</h3>
                  <p class="portfolio-print-dump__entry-meta">{entry.item.issuer}</p>
                  <p class="portfolio-print-dump__entry-period">{entry.item.date}</p>
                  {entry.item.description && <p>{entry.item.description}</p>}
                  {entry.item.bullets.length > 0 && (
                    <ul>
                      {entry.item.bullets.map((bullet) => (
                        <li>{bullet}</li>
