              ))}
            </div>
          </section>
        )}

        {topProjects.length > 0 && (
          <section class="portfolio-print-dump__section">
            <h2>{locale === "ko" ? "프로젝트 아카이브" : "Project Archive"}</h2>
            <div class="portfolio-print-dump__project-archive-grid">
              {topProjects.map((project, index) => {
                return (
                  <article class="portfolio-print-dump__project-archive-card">
                    <p class="portfolio-print-dump__eyebrow">{ui.project.caseStudyLabelPrefix} {index + 1}</p>
                    <h3>{project.data.title}</h3>
                    <p>{project.data.summary}</p>
                    <div class="portfolio-print-dump__project-meta-row">
                      <span>{project.data.year}</span>
                      <span>{project.data.type}</span>
                    </div>
                    <p class="portfolio-print-dump__tag-row">{project.data.roles.join(skillSeparator)}</p>
                  </article>
                );
              })}
            </div>
          </section>
        )}

        {topProjects.length > 0 && topProjects.map((project, index) => {
          const projectLinks = [
            { label: ui.project.linkLabels.repo, href: project.data.repoUrl },
            { label: ui.project.linkLabels.demo, href: project.data.demoUrl },
            { label: ui.project.linkLabels.paper, href: project.data.paperUrl },
            { label: ui.project.linkLabels.slides, href: project.data.slidesUrl }
          ].filter((link) => link.href);

          return (
            <section class="portfolio-print-dump__case-study-page portfolio-print-dump__section--page-start">
                <article class="portfolio-print-dump__project portfolio-print-dump__project--case">
                  <div class="portfolio-print-dump__case-study-topline">
                    <p class="portfolio-print-dump__eyebrow">{locale === "ko" ? "케이스 스터디" : "Case Study"} {index + 1}</p>
                    <span>{project.data.year}</span>
                  </div>
                  <div class="portfolio-print-dump__project-head">
                    <div class="portfolio-print-dump__project-titleblock">
                      <h3>{project.data.title}</h3>
                      <p>{project.data.summary}</p>
                    </div>
                    <div class="portfolio-print-dump__project-meta-row">
                      <span>{project.data.type}</span>
                      <span>{project.data.roles.join(", ")}</span>
                    </div>
                  </div>
                  <div class="portfolio-print-dump__project-body">
                    <article class="portfolio-print-dump__project-block">
                      <h4>{ui.project.fieldLabels.problem}</h4>
                      <p>{project.data.portfolioProblem ?? project.data.summary}</p>
                    </article>
                    <article class="portfolio-print-dump__project-block">
                      <h4>{ui.project.fieldLabels.approach}</h4>
                      <p>{project.data.portfolioApproach ?? project.data.summary}</p>
                    </article>
                    <article class="portfolio-print-dump__project-block">
                      <h4>{ui.project.fieldLabels.outcome}</h4>
                      <p>{project.data.portfolioOutcome ?? project.data.summary}</p>
                    </article>
                  </div>
                  {(project.data.metrics.length > 0 || project.data.tags.length > 0 || projectLinks.length > 0) && (
                    <aside class="portfolio-print-dump__project-aside">
                      {project.data.metrics.length > 0 && (
                        <div class="portfolio-print-dump__project-meta">
                          <h4>{locale === "ko" ? "지표" : "Metrics"}</h4>
                          <div class="portfolio-print-dump__metric-grid">
                            {project.data.metrics.map((metric: string) => (
                              <article class="portfolio-print-dump__metric-card">
                                <span>{metric}</span>
                              </article>
                            ))}
                          </div>
                        </div>
                      )}
                      {project.data.tags.length > 0 && (
                        <div class="portfolio-print-dump__project-meta">
                          <h4>{locale === "ko" ? "기술 및 태그" : "Tech & Tags"}</h4>
                          <div class="portfolio-print-dump__chip-row">
                            {project.data.tags.map((tag: string) => (
                              <span class="portfolio-print-dump__chip">{tag}</span>
                            ))}
                          </div>
                        </div>
                      )}
                      {projectLinks.length > 0 && (
                        <div class="portfolio-print-dump__project-meta">
                          <h4>{locale === "ko" ? "링크" : "Links"}</h4>
                          <div class="portfolio-print-dump__link-stack">
                            {projectLinks.map((link) => (
                              <a class="portfolio-print-dump__link-card" href={link.href} target="_blank" rel="noreferrer">
                                <strong>{link.label}</strong>
                                <span>{link.href}</span>
                              </a>
                            ))}
                          </div>
                        </div>
                      )}
                    </aside>
                  )}
                </article>
            </section>
          );
        })}
      </article>
    </div>
</PrintLayout>

<script is:inline>
  (() => {
    const root = document.querySelector("[data-portfolio-carousel]");
    if (!root) return;

    const viewport = root.querySelector("[data-portfolio-viewport]");
    const track = root.querySelector("[data-portfolio-track]");
    const slides = Array.from(root.querySelectorAll("[data-portfolio-slide]"));
    const prev = root.querySelector("[data-portfolio-prev]");
    const next = root.querySelector("[data-portfolio-next]");

    if (!viewport || !track || slides.length === 0) return;

    let activeIndex = 0;
    let animationFrame = 0;
    let slideWidth = 0;
    let viewportWidth = 0;
    let currentOffset = 0;

    const getTargetOffset = (index) => {
      const safeIndex = Math.max(0, Math.min(index, slides.length - 1));
      const slide = slides[safeIndex];
      if (!slide) return 0;

      return viewportWidth / 2 - (slide.offsetLeft + slide.offsetWidth / 2);
    };

    const updateActive = (index = activeIndex) => {
      activeIndex = Math.max(0, Math.min(index, slides.length - 1));

      slides.forEach((slide, index) => {
        slide.classList.toggle("is-active", index === activeIndex);
        slide.classList.toggle("is-near", Math.abs(index - activeIndex) === 1);
      });
    };

    const applyOffset = (offset, animate = false) => {
      currentOffset = offset;
      track.style.transition = animate ? "transform 520ms cubic-bezier(0.22, 0.8, 0.2, 1)" : "none";
      track.style.transform = `translate3d(${offset}px, 0, 0)`;
    };

    const animateToIndex = (index) => {
      updateActive(index);
      applyOffset(getTargetOffset(activeIndex), true);
    };

    const measure = () => {
      const firstSlide = slides[0];
      if (!firstSlide) return;

      slideWidth = firstSlide.getBoundingClientRect().width;
      viewportWidth = viewport.clientWidth;
      track.style.setProperty("--carousel-edge-space", `${Math.max(0, (viewportWidth - slideWidth) / 2)}px`);
      applyOffset(getTargetOffset(activeIndex), false);
      updateActive(activeIndex);
    };

    const getClosestIndexFromOffset = (offset) => {
      let closestIndex = 0;
      let closestDistance = Number.POSITIVE_INFINITY;

      slides.forEach((_, index) => {
        const distance = Math.abs(getTargetOffset(index) - offset);

        if (distance < closestDistance) {
          closestDistance = distance;
          closestIndex = index;
        }
      });

      return closestIndex;
    };

    const animateOffsetTo = (targetOffset, duration = 520) => {
      const startOffset = currentOffset;
      const distance = targetOffset - startOffset;

      if (Math.abs(distance) < 1) return;

      if (animationFrame) {
        window.cancelAnimationFrame(animationFrame);
      }

      const startTime = performance.now();
      const easeOutCubic = (t) => 1 - Math.pow(1 - t, 3);

      const step = (now) => {
        const elapsed = now - startTime;
        const progress = Math.min(elapsed / duration, 1);
        const eased = easeOutCubic(progress);
        applyOffset(startOffset + distance * eased, false);

        if (progress < 1) {
          animationFrame = window.requestAnimationFrame(step);
          return;
        }

        animationFrame = 0;
        applyOffset(targetOffset, false);
      };

      animationFrame = window.requestAnimationFrame(step);
    };

    const scrollToIndex = (index) => {
      const nextIndex = Math.max(0, Math.min(index, slides.length - 1));
      updateActive(nextIndex);
      animateOffsetTo(getTargetOffset(nextIndex));
    };

    prev?.addEventListener("click", () => {
      scrollToIndex(activeIndex - 1);
    });

    next?.addEventListener("click", () => {
      scrollToIndex(activeIndex + 1);
    });

    let pointerActive = false;
    let startX = 0;
    let startOffset = 0;
    let dragged = false;

    viewport.addEventListener("pointerdown", (event) => {
      if (event.button !== 0) return;
      pointerActive = true;
      dragged = false;
      startX = event.clientX;
      startOffset = currentOffset;
      if (animationFrame) {
        window.cancelAnimationFrame(animationFrame);
        animationFrame = 0;
      }
      viewport.classList.add("is-dragging");
      viewport.setPointerCapture?.(event.pointerId);
    });

    const releasePointer = (event) => {
      if (!pointerActive) return;
      pointerActive = false;
      viewport.classList.remove("is-dragging");
      if (event?.pointerId !== undefined) {
        viewport.releasePointerCapture?.(event.pointerId);
      }
      if (!dragged) return;
      window.requestAnimationFrame(() => {
        const nextIndex = getClosestIndexFromOffset(currentOffset);
        updateActive(nextIndex);
        animateOffsetTo(getTargetOffset(nextIndex));
      });
    };

    viewport.addEventListener("pointermove", (event) => {
      if (!pointerActive) return;
      event.preventDefault();
      const delta = event.clientX - startX;
      if (Math.abs(delta) > 6) {
        dragged = true;
      }
      applyOffset(startOffset + delta, false);
    });

    viewport.addEventListener("pointerup", releasePointer);
    viewport.addEventListener("pointercancel", releasePointer);

    slides.forEach((slide, index) => {
      slide.addEventListener("click", () => {
        if (dragged) return;
        scrollToIndex(index);
      });
    });

    window.addEventListener("resize", () => {
      measure();
    });

    measure();
  })();
</script>

