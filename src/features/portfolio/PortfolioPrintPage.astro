---
import PrintLayout from "../../layouts/PrintLayout.astro";
import PrintToolbar from "../../components/documents/PrintToolbar.astro";
import ExternalLinks from "../../components/common/ExternalLinks.astro";
import { entrySlug, getGlobalEntry, getLocalizedCollection, getPageEntry } from "../../lib/content";
import { localizePath, type Locale } from "../../lib/i18n";
import { withBase } from "../../lib/site";
import { buildPortfolioViewModel } from "./portfolio-data";

interface Props {
  locale: Locale;
  pathname: string;
}

const { locale, pathname } = Astro.props;

const portfolioPage = await getPageEntry("portfolio", locale);
const profileEntry = await getGlobalEntry("profile", locale);
const siteEntry = await getGlobalEntry("site", locale);
const linksEntry = await getGlobalEntry("links", locale);
const recognitionEntry = await getGlobalEntry("recognition", locale);

if (portfolioPage.data.pageType !== "portfolio") {
  throw new Error("Missing portfolio page content configuration.");
}

const profile = profileEntry.data;
const siteConfig = siteEntry.data;
const links = linksEntry.data;

const allProjects = (await getLocalizedCollection("projects", locale))
  .sort((a, b) => b.data.year - a.data.year)
  .map((project) => ({ ...project, slug: entrySlug(project) }));
const allResearch = (await getLocalizedCollection("research", locale))
  .sort((a, b) => b.data.year - a.data.year);

const {
  hero,
  roleThemes,
  featuredCases,
  recognitionEntries,
  researchLinks,
  labels,
  contactItems
} = buildPortfolioViewModel({
  locale,
  profile,
  siteConfig,
  links,
  recognition: recognitionEntry.data,
  portfolioPage,
  allProjects,
  allResearch
});

const webHref = withBase(localizePath("/portfolio/", locale));
const summaryMetrics = featuredCases
  .flatMap((item) => item.metrics.slice(0, 1).map((metric) => ({ ...metric, source: item.title })))
  .slice(0, 3);

const printLabels =
  locale === "ko"
    ? {
        document: "출력용 포트폴리오",
        coverTitle: "AI Systems Engineer",
        roleSummary: "역할 요약",
        evidenceMeta: "증거 메타데이터",
        dataSurfaces: "데이터 표면",
        workflowStages: "AI-DLC 단계",
        selectedEvidence: "대표 증거",
        selectedCases: "대표 케이스",
        reviewPath: "검토 흐름",
        contact: "연락 및 검토 채널",
        architecture: "아키텍처",
        artifacts: "산출물",
        research: "연구 연결",
        recognition: "수료와 수상",
        webPortfolio: "웹 포트폴리오"
      }
    : {
        document: "Print Portfolio",
        coverTitle: "AI Systems Engineer",
        roleSummary: "Role Summary",
        evidenceMeta: "Evidence Metadata",
        dataSurfaces: "Data Surfaces",
        workflowStages: "AI-DLC Stages",
        selectedEvidence: "Selected Evidence",
        selectedCases: "Featured Cases",
        reviewPath: "Review Path",
        contact: "Contact & Review Channels",
        architecture: "Architecture",
        artifacts: "Artifacts",
        research: "Research Bridge",
        recognition: "Recognition",
        webPortfolio: "Web Portfolio"
      };
---

<PrintLayout
  title={`${portfolioPage.data.documentTitle} - ${locale === "ko" ? "인쇄" : "Print"}`}
  description={portfolioPage.data.documentDescription}
  pathname={pathname}
  locale={locale}
>
  <PrintToolbar label={portfolioPage.data.print.label} locale={locale} />

  <article class="paper-sheet paper-sheet--portfolio-print-page portfolio-print-page portfolio-print-cover">
    <header class="portfolio-print-cover__header">
      <p>{printLabels.document}</p>
      <a class="screen-only portfolio-print-page__pill" href={webHref}>{printLabels.webPortfolio}</a>
    </header>

    <section class="portfolio-print-cover__hero">
      <p class="portfolio-print-page__eyebrow">{hero.eyebrow}</p>
      <h1>{printLabels.coverTitle}</h1>
      <p>{hero.title}</p>
      <strong>{hero.valueStatement}</strong>
    </section>

    <section class="portfolio-print-cover__roles">
      <h2>{printLabels.roleSummary}</h2>
      <div>
        {roleThemes.map((role) => (
          <article>
            <span>{role.shortTitle}</span>
            <strong>{role.title}</strong>
            <p>{role.businessSignal}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="portfolio-print-cover__evidence">
      <div>
        <h2>{printLabels.selectedEvidence}</h2>
        <p>{hero.lead}</p>
      </div>
      <div class="portfolio-print-evidence-grid">
        {summaryMetrics.map((metric) => (
          <article>
            <span>{metric.source}</span>
            <strong>{metric.value}</strong>
            <p>{metric.label}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="portfolio-print-cover__cases">
      <h2>{printLabels.selectedCases}</h2>
      <ol>
        {featuredCases.map((item) => (
          <li>
            <span>{item.type} / {item.year}</span>
            <strong>{item.title}</strong>
            <p>{item.value}</p>
          </li>
        ))}
      </ol>
    </section>

    <footer class="portfolio-print-cover__footer">
      {contactItems.slice(0, 3).map((item) => (
        <div>
          <span>{item.label}</span>
          <strong>{item.value}</strong>
        </div>
      ))}
    </footer>
  </article>

  {featuredCases.map((item, index) => (
    <article class="paper-sheet paper-sheet--portfolio-print-page portfolio-print-page portfolio-print-case">
      <header class="portfolio-print-case__header">
        <div>
          <p class="portfolio-print-page__eyebrow">{String(index + 1).padStart(2, "0")} / {item.type} / {item.year}</p>
          <h2>{item.title}</h2>
          <p>{item.thesis}</p>
          <div class="portfolio-print-case__meta-row">
            <span>{item.evidence.evidenceLevel}</span>
            <span>{item.evidence.disclosureLevel}</span>
            <span>{item.evidence.primaryTheme}</span>
          </div>
        </div>
        {item.metrics[0] && (
          <aside>
            <span>{item.metrics[0].label}</span>
            <strong>{item.metrics[0].value}</strong>
          </aside>
        )}
      </header>

      <section class="portfolio-print-case__triad">
        <article>
          <span>{labels.problem}</span>
          <p>{item.problem}</p>
        </article>
        <article>
          <span>{labels.decision}</span>
          <p>{item.decisions[0]?.description}</p>
        </article>
        <article>
          <span>{labels.outcome}</span>
          <p>{item.outcome}</p>
        </article>
      </section>

      {(item.architecture || item.metrics.length > 0) && (
        <section class="portfolio-print-case__evidence">
          {item.architecture && (
            <article class="portfolio-print-case__architecture">
              <h3>{printLabels.architecture}</h3>
              <p>{item.architecture.summary}</p>
              <div>
                {item.architecture.nodes.slice(0, 5).map((node) => (
                  <span>{node.label}</span>
                ))}
              </div>
            </article>
          )}

          {item.metrics.length > 0 && (
            <article class="portfolio-print-case__metrics">
              <h3>{printLabels.selectedEvidence}</h3>
              <div>
                {item.metrics.slice(0, 3).map((metric) => (
                  <p><strong>{metric.value}</strong><span>{metric.label}</span></p>
                ))}
              </div>
            </article>
          )}
        </section>
      )}

      <section class="portfolio-print-case__metadata">
        <article>
          <h3>{printLabels.evidenceMeta}</h3>
          <p>{item.evidence.businessSignal}</p>
        </article>
        <article>
          <h3>{printLabels.dataSurfaces}</h3>
          <div>
            {item.evidence.dataSurfaces.map((surface) => (
              <span>{surface}</span>
            ))}
          </div>
        </article>
        <article>
          <h3>{printLabels.workflowStages}</h3>
          <div>
            {item.evidence.workflowStages.map((stage) => (
              <span>{stage}</span>
            ))}
          </div>
        </article>
      </section>

      {item.artifacts.length > 0 && (
        <section class="portfolio-print-case__artifacts">
          <h3>{printLabels.artifacts}</h3>
          <ExternalLinks
            locale={locale}
            links={item.artifacts.map((artifact) => ({ label: artifact.label, href: artifact.href }))}
          />
        </section>
      )}
    </article>
  ))}

  <article class="paper-sheet paper-sheet--portfolio-print-page portfolio-print-page portfolio-print-closing">
    <section>
      <h2>{printLabels.research}</h2>
      <div class="portfolio-print-closing__list">
        {researchLinks.map(({ entry, linkedCases }) => (
          <article>
            <span>{entry.data.venue} / {entry.data.year}</span>
            <h3>{entry.data.title}</h3>
            {linkedCases.length > 0 && <p>{linkedCases.join(" · ")}</p>}
          </article>
        ))}
      </div>
    </section>

    {recognitionEntries.length > 0 && (
      <section>
        <h2>{printLabels.recognition}</h2>
        <div class="portfolio-print-closing__recognition">
          {recognitionEntries.map((entry) => (
            <article>
              <span>{entry.kind === "certificate" ? (locale === "ko" ? "수료" : "Certificate") : (locale === "ko" ? "수상" : "Award")}</span>
              <h3>{entry.item.title}</h3>
              <p>{entry.item.issuer} / {entry.item.date}</p>
            </article>
          ))}
        </div>
      </section>
    )}
  </article>
</PrintLayout>
