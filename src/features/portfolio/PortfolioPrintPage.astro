---
import PrintLayout from "../../layouts/PrintLayout.astro";
import PrintToolbar from "../../components/documents/PrintToolbar.astro";
import { entrySlug, getGlobalEntry, getLocalizedCollection, getPageEntry } from "../../lib/content";
import { localizePath, type Locale } from "../../lib/i18n";
import { withBase } from "../../lib/site";
import { buildPortfolioViewModel, getPublicDisclosureLabel, getPublicEvidenceLevelLabel } from "./portfolio-data";
import { defaultPrintBudget, takeForPrint } from "../evidence/print-budget";

interface Props {
  locale: Locale;
  pathname: string;
}

const { locale, pathname } = Astro.props;

const portfolioPage = await getPageEntry("portfolio", locale);
const profileEntry = await getGlobalEntry("profile", locale);
const siteEntry = await getGlobalEntry("site", locale);
const linksEntry = await getGlobalEntry("links", locale);
const recognitionEntry = await getGlobalEntry("recognition", locale);

if (portfolioPage.data.pageType !== "portfolio") {
  throw new Error("Missing portfolio page content configuration.");
}

const profile = profileEntry.data;
const siteConfig = siteEntry.data;
const links = linksEntry.data;

const allProjects = (await getLocalizedCollection("projects", locale))
  .sort((a, b) => b.data.year - a.data.year)
  .map((project) => ({ ...project, slug: entrySlug(project) }));
const allResearch = (await getLocalizedCollection("research", locale))
  .sort((a, b) => b.data.year - a.data.year);

const educationEntry = await getGlobalEntry("education", locale);
const educationItems = educationEntry.data.items;

const educationStudySection = portfolioPage.data.web.pages.find((s: any) => s.kind === "educationStudy");
const studyItems = educationStudySection?.studyItems || [];

const enrichedStudyItems = studyItems.map((study: any) => {
  let objective = "";
  let outcomes = "";
  let techStack = "";
  let takeaway = "";
  let reference = "";
  
  if (study.title.includes("NEKA")) {
    objective = locale === "ko" 
      ? "KoBERT 기반 의학 및 국어 도메인의 형태소 분석, 중요 키워드 추출(Keyword Extraction), 개체명 인식(NER) 성능 고도화 및 도메인 특화 사전 구축 학습"
      : "Advanced training on morphosemantics, keyword extraction, and named entity recognition (NER) using KoBERT in specialized medical and native language domains";
    outcomes = locale === "ko"
      ? "PyTorch와 Transformers 라이브러리를 활용해 KoBERT 모델 파인튜닝 파이프라인 설계 및 의학 임상 데이터 NER 처리 F1-Score 0.88 달성 및 시각화 구현"
      : "Designed and implemented a custom KoBERT fine-tuning pipeline in PyTorch, achieving 0.88 NER F1-Score on medical clinical records and validation datasets";
    techStack = "PyTorch, Transformers, KoBERT, Scikit-Learn";
    takeaway = locale === "ko"
      ? "Attention Map 레이어 분석을 통해 의료 전문 용어의 토큰 경계 분절 현상을 정교하게 튜닝하였으며, 도메인 특화 어휘 임베딩 튜닝이 엔티티 boundary 경계 인식에 미치는 높은 민감도를 실증함"
      : "Analyzed Multi-Head Attention maps to study medical token boundary segmentation, proving the high sensitivity of specialized domain vocabulary embeddings on boundary accuracy";
    reference = locale === "ko"
      ? "Attention Is All You Need (Vaswani et al., 2017) 및 BERT (Devlin et al., 2018)의 트랜스포머 아키텍처 이론 분석"
      : "Theoretical analysis of Transformer architecture in Attention Is All You Need (Vaswani, 2017) and BERT (Devlin, 2018)";
  } else if (study.title.includes("수나로움") || study.title.includes("Sunaroum")) {
    objective = locale === "ko"
      ? "금융 시계열 거시 경제 지표 및 재무제표 텍스트 데이터를 멀티모달 형태로 결합하여 매수/매도 시그널을 생성하는 실무 퀀트 트레이딩 모델 아키텍처 설계"
      : "Designing practical quantitative trading models combining financial time-series indicators with unstructured financial report text datasets in a multimodal way";
    outcomes = locale === "ko"
      ? "재무 지표 변수 임베딩과 XGBoost 예측 모델을 결합하고 Backtrader를 활용해 수익률 극대화 및 최대 낙폭(MDD) 제어 성능을 검증하는 투자 백테스팅 시스템 설계"
      : "Designed an investment backtesting framework combining financial variable embedding and XGBoost predictors, testing MDD constraints and yield curves via Backtrader";
    techStack = "XGBoost, Pandas, Numpy, Backtrader";
    takeaway = locale === "ko"
      ? "이종 데이터(시계열+텍스트) 결합 시 단순 concatenation보다 gating 메커니즘을 적용하는 것이 노이즈가 많은 금융 도메인에서 모델 오버핏을 방지하고 강건한 일반화 신호 생성에 효과적임을 실증함"
      : "Demonstrated that applying a gating network for heterogeneous inputs (time-series + text) is far more robust against overfitting and noise than basic concatenation";
    reference = locale === "ko"
      ? "Multimodal Deep Learning (Ngiam et al., 2011) 및 XGBoost: A Scalable Tree Boosting System (Chen et al., 2016) 수식 분석"
      : "Mathematical analysis of Multimodal Deep Learning (Ngiam, 2011) and XGBoost: A Scalable Tree Boosting System (Chen, 2016)";
  } else if (study.title.includes("이다") || study.title.includes("Ida")) {
    objective = locale === "ko"
      ? "Heterogeneous 정보 네트워크 환경에서 지식 그래프(Knowledge Graph)의 개체 임베딩 및 GCN/GAT 모델을 결합한 하이브리드 고도화 추천 모델 아키텍처 분석"
      : "Analyzing hybrid recommender systems combining Knowledge Graph entity embeddings and GCN/GAT model structures in heterogeneous information networks";
    outcomes = locale === "ko"
      ? "MovieLens 데이터 기반 Heterogeneous Graph 추천 모델을 PyG(PyTorch Geometric) 프로토타입으로 개발하여 Collaborative Filtering 대비 한계 성능 극복 검증"
      : "Implemented a heterogeneous graph recommender system prototype using PyG (PyTorch Geometric) on MovieLens data, validating hits and NDCG metrics against CF baselines";
    techStack = "PyTorch Geometric (PyG), DGL, NetworkX, GNN";
    takeaway = locale === "ko"
      ? "Heterogeneous 그래프 상에서 메타패스(Meta-path) 기반의 관계형 에지 임베딩 전파 메커니즘을 정의함으로써, 추천 시스템의 고질적인 문제인 유저/아이템 콜드 스타트 문제를 대폭 완화하는 해결책을 도출함"
      : "Proved that defining meta-path based relational edge embeddings in graph neural networks significantly mitigates user/item cold-start recommendations";
    reference = locale === "ko"
      ? "Semi-Supervised Classification with GCN (Kipf et al., 2016) 및 Graph Attention Networks (GAT) (Veličković et al., 2018) 연구"
      : "Deep study of Semi-Supervised Classification with GCN (Kipf, 2016) and Graph Attention Networks (GAT) (Veličković, 2018)";
  } else if (study.title.includes("MLADS")) {
    objective = locale === "ko"
      ? "확률분포, 베이지안 추론, 선형대수학 등 통계학적 기초 위에 머신러닝의 수렴성, 최적화 및 복잡한 정규화 메커니즘의 수학적 정형화를 깊이 있게 탐구하는 학습"
      : "Deep mathematical formulation of machine learning optimization, convergence, and complex regularization mechanisms on top of probability and linear algebra";
    outcomes = locale === "ko"
      ? "주요 차원 축소 알고리즘(PCA, t-SNE) 및 핵심 지도학습 수식들을 밑바닥(Scratch)부터 NumPy로 직접 수학적으로 유도하고 코드로 구현하여 수치적 최적화 신뢰도 검증"
      : "Derived mathematical equations and implemented dimensionality reductions (PCA, t-SNE) and classifiers from pure NumPy scratch, validating optimization loss";
    techStack = "Python, NumPy, SciPy, Matplotlib";
    takeaway = locale === "ko"
      ? "수학적 수식을 증명하고 직접 알고리즘을 빌딩함으로써, 프레임워크 추상화 레이어 뒤에 숨겨진 그라디언트 소실(Vanishing Gradient) 및 로컬 미니마 최적화 제약 조건과 수렴 속도 한계를 깊이 있게 명확히 체득함"
      : "Acquired precise mental models of convergence bottlenecks, vanishing gradients, and local minima boundary conditions by implementing algorithms mathematically from scratch";
    reference = locale === "ko"
      ? "Deep Learning (Goodfellow et al., 2016) 및 Pattern Recognition and Machine Learning (PRML) (Bishop, 2006) 확률론/선형대수 기초"
      : "Foundations of probability and linear algebra in Deep Learning (Goodfellow, 2016) & PRML (Bishop, 2006) reference studies";
  }
  
  return {
    ...study,
    objective,
    outcomes,
    techStack,
    takeaway,
    reference
  };
});

const communityItems = [
  {
    date: "2024.03",
    title: locale === "ko" ? "AWS Builders Online Series 이수" : "AWS Builders Online Series",
    issuer: "AWS",
    description: locale === "ko"
      ? "서버리스 아키텍처 및 Amazon Bedrock 기반 생성형 AI 어플리케이션 통합 워크플로 학습"
      : "Learned serverless architectures and generative AI application integration workflows based on Amazon Bedrock"
  },
  {
    date: "2023.08",
    title: locale === "ko" ? "오픈소스 NLP/LLM 지속 학습" : "Open-source NLP/LLM Continuous Learning",
    issuer: "Community",
    description: locale === "ko"
      ? "오픈소스 LLM 경량 최적화(LoRA, QLoRA) 기법 및 RAG 패턴 기반 검색 증강 생성 실무 아키텍처 분석"
      : "Analyzed open-source LLM parameter-efficient fine-tuning (LoRA, QLoRA) and RAG pattern architectures"
  }
];





const {
  hero,
  roleThemes,
  evidenceGroups,
  labels,
  contactItems
} = buildPortfolioViewModel({
  locale,
  profile,
  siteConfig,
  links,
  recognition: recognitionEntry.data,
  portfolioPage,
  allProjects,
  allResearch
});

// Verification Matrix Mappings for Research and Studies
const researchMatrixItems = allResearch.map((paper) => {
  const roles: Record<string, string> = {};
  const linked = paper.data.linkedRoles || [];
  
  if (linked.includes("nlp-llm")) roles["nlp-llm"] = "primary";
  if (linked.includes("data-graph")) roles["data-graph"] = "supporting";
  if (linked.includes("aidlc-mlops")) roles["aidlc-mlops"] = "supporting";

  if (paper.data.title.includes("게이트 임베딩")) {
    roles["nlp-llm"] = "primary";
    roles["data-graph"] = "supporting";
  } else if (paper.data.title.includes("간호감시")) {
    roles["nlp-llm"] = "primary";
    roles["data-graph"] = "supporting";
  } else if (paper.data.title.includes("공감 대화")) {
    roles["nlp-llm"] = "primary";
  }

  return {
    title: paper.data.title,
    year: paper.data.year,
    type: locale === "ko" ? "연구 논문" : "Research",
    roles
  };
});

const studyMatrixItems = [
  {
    title: "NEKA: NLP 스터디 (KoBERT)",
    year: 2023,
    type: locale === "ko" ? "학습 스터디" : "Study",
    roles: {
      "nlp-llm": "primary"
    }
  },
  {
    title: locale === "ko" ? "수나로움: 금융 AI 스터디" : "Sunaroum: Financial AI Study",
    year: 2023,
    type: locale === "ko" ? "학습 스터디" : "Study",
    roles: {
      "nlp-llm": "primary",
      "aidlc-mlops": "supporting"
    }
  },
  {
    title: locale === "ko" ? "이다: 추천 시스템 스터디 (지식 그래프)" : "Ida: Recommender Systems Study",
    year: 2022,
    type: locale === "ko" ? "학습 스터디" : "Study",
    roles: {
      "data-graph": "primary"
    }
  },
  {
    title: "MLADS: 머신러닝 기초 스터디",
    year: 2022,
    type: locale === "ko" ? "학습 스터디" : "Study",
    roles: {
      "data-graph": "primary",
      "aidlc-mlops": "supporting"
    }
  }
];

const webHref = withBase(localizePath("/portfolio/", locale));
const printCases = Array.from(
  new Map(
    evidenceGroups
      .flatMap((group: any) => group.items)
      .map((item: any) => [item.slug, item])
  ).values()
);
const printRecognitionEntries = [
  ...(recognitionEntry.data.certificates ?? []).map((item: any) => ({ kind: "certificate" as const, item })),
  ...(recognitionEntry.data.awards ?? []).map((item: any) => ({ kind: "award" as const, item }))
];
const getRoleMatrixStatus = (item: any, roleId: string) => {
  if (item.evidence.primaryTheme === roleId) return "primary";
  if (item.evidence.secondaryThemes?.includes(roleId)) return "supporting";
  return "empty";
};
const getRoleMatrixLabel = (status: string, locale: Locale) => {
  if (status === "primary") return locale === "ko" ? "주요 역할" : "Primary";
  if (status === "supporting") return locale === "ko" ? "연결된 축" : "Supporting";
  return "—";
};
const roleColors = {
  nlp: "var(--role-nlp)",
  data: "var(--role-data)",
  aidlc: "var(--role-aidlc)",
  muted: "var(--color-border)",
  textMuted: "var(--color-text-muted)"
};

const printLabels =
  locale === "ko"
    ? {
        document: "출력용 포트폴리오",
        coverTitle: "Data & Applied AI Engineer",
        roleSummary: "역할 요약",
        evidenceMeta: "검토 포인트",
        dataSurfaces: "데이터 표면",
        workflowStages: "AI-DLC 단계",
        selectedEvidence: "대표 작업",
        selectedCases: "대표 케이스",
        reviewPath: "검토 흐름",
        contact: "연락 및 검토 채널",
        architecture: "아키텍처",
        artifacts: "산출물",
        research: "연구 연결",
        recognition: "수료와 수상",
        webPortfolio: "웹 포트폴리오",
        constraints: "제약 제어",
        decisions: "설계 결정과 트레이드오프",
        reflection: "프로젝트 회고와 레슨런"
      }
    : {
        document: "Print Portfolio",
        coverTitle: "Data & Applied AI Engineer",
        roleSummary: "Role Summary",
        evidenceMeta: "Review Points",
        dataSurfaces: "Data Surfaces",
        workflowStages: "AI-DLC Stages",
        selectedEvidence: "Selected Work",
        selectedCases: "Featured Cases",
        reviewPath: "Review Path",
        contact: "Contact & Review Channels",
        architecture: "Architecture",
        artifacts: "Artifacts",
        research: "Research Bridge",
        recognition: "Recognition",
        webPortfolio: "Web Portfolio",
        constraints: "Constraints",
        decisions: "Design Decisions",
        reflection: "Retrospective & Lessons Learned"
      };
const unifyingThesis =
  locale === "ko"
    ? "데이터 구조화, AI 개발 흐름, NLP/LLM 평가 경험을 바탕으로 문제 정의부터 구현, 검증, 전달까지 이어지는 작업을 수행한다."
    : "I work across data structure, AI development workflows, and NLP/LLM evaluation, carrying problems from framing to implementation, validation, and delivery.";
---

<PrintLayout
  title={`${portfolioPage.data.documentTitle} - ${locale === "ko" ? "인쇄" : "Print"}`}
  description={portfolioPage.data.documentDescription}
  pathname={pathname}
  locale={locale}
>
  <div data-density="print-a4">
  <PrintToolbar label={portfolioPage.data.print.label} locale={locale} />

  <!-- Global SVG definitions for case study custom triangles -->
  <svg style="position: absolute; width: 0; height: 0; overflow: hidden;" version="1.1" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <linearGradient id="gradient-nlp-data" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color={roleColors.nlp} />
        <stop offset="100%" stop-color={roleColors.data} />
      </linearGradient>
      <linearGradient id="gradient-nlp-mlops" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color={roleColors.nlp} />
        <stop offset="100%" stop-color={roleColors.aidlc} />
      </linearGradient>
      <linearGradient id="gradient-data-mlops" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color={roleColors.data} />
        <stop offset="100%" stop-color={roleColors.aidlc} />
      </linearGradient>
    </defs>
  </svg>

  <article class="paper-sheet paper-sheet--portfolio-print-page portfolio-print-page portfolio-print-cover">
    <!-- Calibration Corner Marks for screen blueprint aesthetic -->
    <div class="blueprint-corner blueprint-corner--top-left screen-only"></div>
    <div class="blueprint-corner blueprint-corner--top-right screen-only"></div>
    <div class="blueprint-corner blueprint-corner--bottom-left screen-only"></div>
    <div class="blueprint-corner blueprint-corner--bottom-right screen-only"></div>
    <div class="blueprint-page-spec screen-only">SYS_SHEET_01 / COVER</div>

    <header class="portfolio-print-cover__header">
      <p>{printLabels.document}</p>
      <a class="screen-only portfolio-print-page__pill" href={webHref}>{printLabels.webPortfolio}</a>
    </header>

    <section class="portfolio-print-cover__hero">
      <p class="portfolio-print-page__eyebrow">{hero.eyebrow}</p>
      <h1>{printLabels.coverTitle}</h1>
      <p class="portfolio-print-cover__hero-title">{hero.title}</p>
      <div class="portfolio-print-cover__thesis">
        <p>{unifyingThesis}</p>
      </div>
    </section>

    <!-- Synergy Diagram SVG -->
    <div class="portfolio-print-cover__synergy-diagram">
      <svg class="career-synergy-triangle" viewBox="0 0 400 215" xmlns="http://www.w3.org/2000/svg" style="max-height: 140px; width: 100%;">
        <defs>
          <linearGradient id="grad-nlp-data" x1="50%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color={roleColors.nlp} />
            <stop offset="100%" stop-color={roleColors.data} />
          </linearGradient>
          <linearGradient id="grad-nlp-mlops" x1="50%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color={roleColors.nlp} />
            <stop offset="100%" stop-color={roleColors.aidlc} />
          </linearGradient>
          <linearGradient id="grad-data-mlops" x1="0%" y1="100%" x2="100%" y2="100%">
            <stop offset="0%" stop-color={roleColors.data} />
            <stop offset="100%" stop-color={roleColors.aidlc} />
          </linearGradient>
          <radialGradient id="center-glow" cx="50%" cy="58%" r="40%">
            <stop offset="0%" stop-color="#2563eb" stop-opacity="0.08" />
            <stop offset="100%" stop-color="#ffffff" stop-opacity="0" />
          </radialGradient>
        </defs>

        <!-- Concentric radar guidelines centered at triangle centroid (200, 126) -->
        <circle cx="200" cy="126" r="45" fill="none" stroke="#cbd5e1" stroke-width="0.75" stroke-dasharray="2,4" opacity="0.5" />
        <circle cx="200" cy="126" r="90" fill="none" stroke="#cbd5e1" stroke-width="0.75" stroke-dasharray="2,4" opacity="0.35" />
        <circle cx="200" cy="126" r="135" fill="none" stroke="#cbd5e1" stroke-width="0.5" stroke-dasharray="1,3" opacity="0.2" />
        
        <!-- Radar reticle crosshairs -->
        <line x1="200" y1="111" x2="200" y2="141" stroke="#cbd5e1" stroke-width="0.75" opacity="0.5" />
        <line x1="185" y1="126" x2="215" y2="126" stroke="#cbd5e1" stroke-width="0.75" opacity="0.5" />
        
        <!-- Shaded center -->
        <polygon points="200,30 90,175 310,175" fill="url(#center-glow)" stroke="#cbd5e1" stroke-width="1" stroke-dasharray="3,3" />
        
        <!-- Connecting axis lines -->
        <line x1="200" y1="30" x2="90" y2="175" stroke="url(#grad-nlp-data)" stroke-width="3" stroke-linecap="round" />
        <line x1="200" y1="30" x2="310" y2="175" stroke="url(#grad-nlp-mlops)" stroke-width="3" stroke-linecap="round" />
        <line x1="90" y1="175" x2="310" y2="175" stroke="url(#grad-data-mlops)" stroke-width="3" stroke-linecap="round" />

        <!-- Glow/Outer circles around nodes -->
        <circle cx="200" cy="30" r="12" fill="#f5f3ff" stroke={roleColors.nlp} stroke-width="1.5" />
        <circle cx="90" cy="175" r="12" fill="#f0fdfa" stroke={roleColors.data} stroke-width="1.5" />
        <circle cx="310" cy="175" r="12" fill="#eff6ff" stroke={roleColors.aidlc} stroke-width="1.5" />

        <!-- Node center points -->
        <circle cx="200" cy="30" r="4.5" fill={roleColors.nlp} />
        <circle cx="90" cy="175" r="4.5" fill={roleColors.data} />
        <circle cx="310" cy="175" r="4.5" fill={roleColors.aidlc} />

        <!-- Axis Labels -->
        <g class="axis-label" transform="translate(122, 98) rotate(-51)">
          <rect x="-60" y="-7" width="120" height="14" rx="3" fill="#ffffff" fill-opacity="0.95" stroke="#cbd5e1" stroke-width="0.5" />
