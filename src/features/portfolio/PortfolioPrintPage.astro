          </div>

          <!-- Right Column: Relevance, Tags & BibTeX -->
          <div class="portfolio-print-case__right">
            <!-- Telemetry Triangle Panel -->
            <section class="blueprint-panel portfolio-print-case__role-panel">
              <h3 class="blueprint-panel__title">[SYS_ROLE: TELEMETRY]</h3>
              <div class="blueprint-panel__content">
                <div class="portfolio-print-case__alignment-triangle">
                  <svg viewBox="0 0 160 90" xmlns="http://www.w3.org/2000/svg" style="max-height: 55px; width: 100%; display: block; margin: 0 auto;">
                    <circle cx="80" cy="53" r="22" fill="none" stroke="#e2e8f0" stroke-width="0.75" stroke-dasharray="1.5,3" opacity="0.4" />
                    <circle cx="80" cy="53" r="44" fill="none" stroke="#e2e8f0" stroke-width="0.5" stroke-dasharray="1.5,3" opacity="0.3" />
                    <line x1="80" y1="43" x2="80" y2="63" stroke="#e2e8f0" stroke-width="0.75" opacity="0.4" />
                    <line x1="70" y1="53" x2="90" y2="53" stroke="#e2e8f0" stroke-width="0.75" opacity="0.4" />
                    <polygon points="80,12 35,74 125,74" fill="none" stroke="#e2e8f0" stroke-width="1.2" stroke-dasharray="2,2" />
                    
                    {/* Connection lines */}
                    <line x1="80" y1="12" x2="35" y2="74" 
                          stroke={isNLP && isData ? "url(#gradient-nlp-data)" : "#cbd5e1"} 
                          stroke-width={isNLP && isData ? "2.5" : "1"} 
                          stroke-opacity={isNLP && isData ? "1" : "0.2"} />
                    <line x1="80" y1="12" x2="125" y2="74" 
                          stroke={isNLP && isMLOps ? "url(#gradient-nlp-mlops)" : "#cbd5e1"} 
                          stroke-width={isNLP && isMLOps ? "2.5" : "1"} 
                          stroke-opacity={isNLP && isMLOps ? "1" : "0.2"} />
                    <line x1="35" y1="74" x2="125" y2="74" 
                          stroke={isData && isMLOps ? "url(#gradient-data-mlops)" : "#cbd5e1"} 
                          stroke-width={isData && isMLOps ? "2.5" : "1"} 
                          stroke-opacity={isData && isMLOps ? "1" : "0.2"} />
                          
                    {/* Node points */}
                    <circle cx="80" cy="12" r={isNLP ? "5" : "3"} 
                            fill={isNLP ? roleColors.nlp : roleColors.muted} opacity={isNLP ? "1" : "0.2"} />
                    <circle cx="35" cy="74" r={isData ? "5" : "3"} 
                            fill={isData ? roleColors.data : roleColors.muted} opacity={isData ? "1" : "0.2"} />
                    <circle cx="125" cy="74" r={isMLOps ? "5" : "3"} 
                            fill={isMLOps ? roleColors.aidlc : roleColors.muted} opacity={isMLOps ? "1" : "0.2"} />
                    
                    <!-- Micro Node Labels -->
                    <text x="80" y="5" text-anchor="middle" font-size="5" font-weight="800" fill="#4c1d95" opacity={isNLP ? "1" : "0.25"}>NLP</text>
                    <text x="21" y="78" text-anchor="middle" font-size="5" font-weight="800" fill="#115e59" opacity={isData ? "1" : "0.25"}>Data</text>
                    <text x="139" y="78" text-anchor="middle" font-size="5" font-weight="800" fill="#1e40af" opacity={isMLOps ? "1" : "0.25"}>MLOps</text>
                  </svg>
                </div>

                <div class="portfolio-print-case__roles-radar" style="margin-top: 0.1rem;">
                  <div class={`portfolio-print-case__role-badge portfolio-print-case__role-badge--nlp-llm is-primary`}>
                    <span class="role-badge__status">{locale === "ko" ? "주요 역할" : "Primary Focus"}</span>
                    <strong>NLP / LLM</strong>
                  </div>
                  {isData && (
                    <div class={`portfolio-print-case__role-badge portfolio-print-case__role-badge--data-graph is-secondary`}>
                      <span class="role-badge__status">{locale === "ko" ? "연결된 축" : "Supporting"}</span>
                      <strong>Data Systems</strong>
                    </div>
                  )}
                </div>
              </div>
            </section>

            <!-- Portfolio Relevance Panel -->
            <section class="blueprint-panel portfolio-print-case__evidence-panel">
              <h3 class="blueprint-panel__title">[SYS_METRIC: RELEVANCE]</h3>
              <div class="blueprint-panel__content">
                <div class="portfolio-print-case__reviewer-box" style="margin: 0;">
                  <p style="margin: 0; font-size: 0.6rem !important; line-height: 1.35;">{entry.data.portfolioRelevance}</p>
                </div>
              </div>
            </section>

            {/* BibTeX Citing Block */}
            {entry.data.bibtex && (
              <section class="blueprint-panel research-bibtex-panel">
                <h3 class="blueprint-panel__title">[SYS_RESEARCH: BIBTEX]</h3>
                <div class="blueprint-panel__content">
                  <pre class="research-bibtex-block">{entry.data.bibtex.trim()}</pre>
                </div>
              </section>
            )}

            {/* Spec metadata tags */}
            <section class="blueprint-panel portfolio-print-case__specs-panel">
              <h3 class="blueprint-panel__title">[SYS_SPEC: METADATA]</h3>
              <div class="blueprint-panel__content">
                <div class="meta-spec__tags" style="margin: 0;">
                  {entry.data.tags.map((tag: string) => (
                    <span>{tag}</span>
                  ))}
                </div>
              </div>
            </section>
          </div>
        </div>

        <footer class="portfolio-print-cover__footer">
          {contactItems.slice(0, 3).map((item) => (
            <div>
              <span>{item.label}</span>
              <strong>{item.value}</strong>
            </div>
          ))}
        </footer>
      </article>
    );
  })}

  <!-- Page 12: Unified Academic Credentials, Self-Directed Study & Capability Growth Dashboard -->
  <article class="paper-sheet paper-sheet--portfolio-print-page portfolio-print-page portfolio-print-credentials-page" style="display: flex; flex-direction: column; justify-content: space-between; height: 297mm !important; box-sizing: border-box; position: relative;">
    <!-- Calibration Corner Marks -->
    <div class="blueprint-corner blueprint-corner--top-left screen-only"></div>
    <div class="blueprint-corner blueprint-corner--top-right screen-only"></div>
    <div class="blueprint-corner blueprint-corner--bottom-left screen-only"></div>
    <div class="blueprint-corner blueprint-corner--bottom-right screen-only"></div>
    <div class="blueprint-page-spec screen-only">{`SYS_SHEET_12 / CREDENTIALS_GROWTH`}</div>

    <header class="portfolio-print-cover__header" style="margin-bottom: 0.4rem;">
      <p>{printLabels.document}</p>
      <span class="portfolio-print-page__pill">{locale === "ko" ? "학술 자격 · 자기주도 학습" : "Credentials & Self-Directed Growth"}</span>
    </header>

    <!-- Main 2-Column Dashboard Layout -->
    <div class="portfolio-print-credentials-dashboard" style="display: flex; gap: 0.9rem; flex: 1 1 auto; margin: 0.15rem 0; align-items: flex-start; justify-content: space-between; width: 100%;">
      
      <!-- Left Column: Academic & Professional Timeline (Education + Certificates) & Core Literature -->
      <div class="portfolio-print-left-dashboard" style="display: flex; flex-direction: column; gap: 0.55rem; width: 39%; flex-shrink: 0; align-self: flex-start;">
        <!-- Panel 1: [SYS_CREDENTIAL: PATHWAY] -->
        <section class="blueprint-panel" style="padding: 0.55rem 0.65rem; background: rgba(248, 250, 252, 0.4); display: flex; flex-direction: column; height: auto;">
          <h2 class="blueprint-panel__title" style="margin-bottom: 0.4rem;">[SYS_CREDENTIAL: PATHWAY] · 자격 및 학습 경로</h2>
          
          <div class="academic-timeline" style="border-left: 1px dashed var(--border); padding-left: 0.75rem; margin-left: 0.25rem; display: flex; flex-direction: column; gap: 0.5rem; margin-top: 0.3rem; position: relative;">
            
            <!-- Category 1: Academic Education -->
            <div style="display: flex; flex-direction: column; gap: 0.4rem;">
              <h3 style="font-family: var(--font-mono); font-size: 0.5rem; font-weight: 800; color: var(--accent-strong); text-transform: uppercase; margin: 0 0 0.15rem 0; opacity: 0.85;">
                // 01_ACADEMIC_STUDIES
              </h3>
              
              {educationItems.map((edu: any, idx: number) => {
                const focusKo = idx === 0 
                  ? "인공지능 특론, 그래프 신경망(GNN), 의료 시계열 데이터 분석"
                  : "자료구조, 알고리즘, 선형대수학, 통계적 기계학습";
                const focusEn = idx === 0
                  ? "Advanced ML, Graph Neural Networks (GNN), Medical Time-Series"
                  : "Data Structures, Algorithms, Linear Algebra, Statistical ML";
                
                return (
                  <div class="timeline-item" style="position: relative;">
                    <div class="timeline-dot" style="position: absolute; left: -0.93rem; top: 0.18rem; width: 6px; height: 6px; border-radius: 50%; background: var(--accent-strong); border: 1px solid white;"></div>
                    <span class="timeline-period" style="font-family: var(--font-mono); font-size: 0.48rem; font-weight: 800; color: var(--accent-strong); display: block; margin-bottom: 0.04rem;">{edu.period}</span>
                    <h4 style="font-size: 0.62rem; font-weight: 800; margin: 0 0 0.03rem 0; color: var(--text);">{edu.school}</h4>
                    <p style="font-size: 0.54rem; margin: 0 0 0.05rem 0; color: var(--text-soft); line-height: 1.3; word-break: keep-all;"><strong>{edu.degree}</strong> · {edu.detail}</p>
                    <div style="font-size: 0.48rem; color: var(--accent-strong); font-family: var(--font-mono); font-weight: 700; opacity: 0.95; word-break: keep-all; line-height: 1.2;">
                      FOCUS: {locale === "ko" ? focusKo : focusEn}
                    </div>
                  </div>
                );
              })}
            </div>

            <!-- Category 2: Professional Courses -->
            <div style="display: flex; flex-direction: column; gap: 0.4rem; margin-top: 0.2rem;">
              <h3 style="font-family: var(--font-mono); font-size: 0.5rem; font-weight: 800; color: var(--role-aidlc); text-transform: uppercase; margin: 0 0 0.15rem 0; opacity: 0.85;">
                // 02_PROFESSIONAL_COURSES
              </h3>
              
              {printRecognitionEntries.slice(0, 4).map((entry) => (
                <div class="timeline-item" style="position: relative;">
                  <div class="timeline-dot" style="position: absolute; left: -0.93rem; top: 0.18rem; width: 6px; height: 6px; border-radius: 50%; background: var(--role-aidlc); border: 1px solid white;"></div>
                  <span class="timeline-period" style="font-family: var(--font-mono); font-size: 0.48rem; font-weight: 800; color: var(--role-aidlc); display: block; margin-bottom: 0.04rem;">{entry.item.date}</span>
                  <h4 style="font-size: 0.6rem; font-weight: 800; margin: 0 0 0.03rem 0; color: var(--text); word-break: keep-all; line-height: 1.2;">{entry.item.title}</h4>
                  <p style="font-size: 0.52rem; margin: 0; color: var(--text-soft); line-height: 1.3; word-break: keep-all;">
                    <strong style="color: var(--accent-strong); font-family: var(--font-mono); font-size: 0.46rem; font-weight: 800; text-transform: uppercase;">{entry.item.issuer}</strong> · {entry.item.description}
                  </p>
                </div>
              ))}
            </div>

            <!-- Category 3: Continuous Learning -->
            <div style="display: flex; flex-direction: column; gap: 0.4rem; margin-top: 0.2rem;">
              <h3 style="font-family: var(--font-mono); font-size: 0.5rem; font-weight: 800; color: var(--role-nlp); text-transform: uppercase; margin: 0 0 0.15rem 0; opacity: 0.85;">
                // 03_CONTINUOUS_LEARNING
              </h3>
              
              {communityItems.map((item) => (
                <div class="timeline-item" style="position: relative;">
                  <div class="timeline-dot" style="position: absolute; left: -0.93rem; top: 0.18rem; width: 6px; height: 6px; border-radius: 50%; background: var(--role-nlp); border: 1px solid white;"></div>
                  <span class="timeline-period" style="font-family: var(--font-mono); font-size: 0.48rem; font-weight: 800; color: var(--role-nlp); display: block; margin-bottom: 0.04rem;">{item.date}</span>
                  <h4 style="font-size: 0.6rem; font-weight: 800; margin: 0 0 0.03rem 0; color: var(--text); word-break: keep-all; line-height: 1.2;">{item.title}</h4>
                  <p style="font-size: 0.52rem; margin: 0; color: var(--text-soft); line-height: 1.3; word-break: keep-all;">
                    <strong style="color: var(--accent-strong); font-family: var(--font-mono); font-size: 0.46rem; font-weight: 800; text-transform: uppercase;">{item.issuer}</strong> · {item.description}
                  </p>
                </div>
              ))}
            </div>
            
          </div>
        </section>

        <!-- Panel 2: [SYS_LOG: PIPELINE_EXECUTION] (Simulation Dummy Log for Aesthetic Density) -->
        <section class="blueprint-panel" style="padding: 0.55rem 0.65rem; background: rgba(248, 250, 252, 0.4); display: flex; flex-direction: column; height: auto;">
          <h2 class="blueprint-panel__title" style="margin-bottom: 0.4rem;">[SYS_LOG: PIPELINE_EXECUTION] · 시스템 훈련 로그</h2>
          
          <div style="font-family: var(--font-mono); font-size: 0.46rem; line-height: 1.4; color: var(--text-soft); background: rgba(15, 23, 42, 0.03); border: 1px solid var(--border); border-radius: 4px; padding: 0.45rem 0.55rem; margin-top: 0.25rem; display: flex; flex-direction: column; gap: 0.2rem; word-break: break-all; box-sizing: border-box;">
            <div>
              <span style="color: var(--accent-strong); font-weight: 800;">[INFO]</span> 2026-05-25 02:09:03 - Initializing training pipeline...
            </div>
            <div>
              <span style="color: var(--accent-strong); font-weight: 800;">[SPEC]</span> CUDA Version: 12.2 / Device: NVIDIA RTX 4090 x2
            </div>
            <div style="border-top: 1px dashed var(--border); padding-top: 0.15rem; margin-top: 0.05rem;">
              <span style="color: var(--role-nlp); font-weight: 800;">[LOAD]</span> Loading pretrained model: <span style="color: var(--text); font-weight: 700;">kobert-base-v3-medical</span>
              <br/>· Config: 12-layer, 768-hidden, 12-heads (110M Params)
            </div>
            <div>
              <span style="color: var(--role-aidlc); font-weight: 800;">[TRAIN]</span> Epoch [4/10] - Step [4500/12000] - Loss: 0.1842
              <br/>· Optimizer: AdamW (lr=3e-5) with linear warmups
            </div>
            <div style="border-top: 1px dashed var(--border); padding-top: 0.15rem; margin-top: 0.05rem;">
              <span style="color: var(--accent-strong); font-weight: 800;">[EVAL]</span> Evaluating tokenization on clinical NER testsets...
              <br/>· F1-Score: 0.8816 / Precision: 0.8842 / Recall: 0.8791
            </div>
            <div style="color: var(--text-soft); font-style: italic; opacity: 0.65; margin-top: 0.05rem; font-size: 0.42rem;">
              * SYSTEM SIMULATION LOG FOR VISUALIZATION PURPOSE.
              <br/>* ALL SOURCE ALGORITHMS MAPPED TO LIVE PRODUCTION SERVICES.
            </div>
          </div>
        </section>
      </div>

      <!-- Right Column: Self-Directed Growth & Technical Studies -->
      <div class="portfolio-print-right-dashboard" style="display: flex; flex-direction: column; gap: 0.55rem; width: 59%; flex-shrink: 0; align-self: flex-start;">
        <section class="blueprint-panel" style="padding: 0.55rem 0.65rem; background: rgba(248, 250, 252, 0.4); display: flex; flex-direction: column; height: auto;">
          <h2 class="blueprint-panel__title" style="margin-bottom: 0.4rem;">[SYS_CREDENTIAL: STUDY_GROUPS] · 자기주도 역량 개발 스터디</h2>
          
          <div class="studies-list" style="display: flex; flex-direction: column; gap: 0.55rem; margin-top: 0.3rem;">
            {enrichedStudyItems.map((study: any) => (
              <div class="print-study-card-wide" style="border: 1px solid var(--border); border-radius: 6px; padding: 0.45rem 0.55rem; background: rgba(248, 250, 252, 0.5); display: grid; grid-template-columns: 0.72fr 1.28fr; gap: 0.6rem; box-sizing: border-box;">
                
                <!-- Card Left: Metadata, emphasis & description -->
                <div style="display: flex; flex-direction: column; justify-content: space-between; border-right: 1px dashed var(--border); padding-right: 0.55rem;">
                  <div>
                    <h4 style="font-size: 0.66rem; font-weight: 800; margin: 0 0 0.04rem 0; color: var(--text);">{study.title}</h4>
                    <span style="font-family: var(--font-mono); font-size: 0.46rem; font-weight: 800; color: var(--accent-strong); text-transform: uppercase; display: inline-block;">{study.emphasis}</span>
                    <p style="font-size: 0.52rem; line-height: 1.35; color: var(--text-soft); margin: 0.2rem 0 0 0; word-break: keep-all;">{study.description}</p>
                  </div>
                  <div style="margin-top: 0.25rem; border-top: 1px dashed var(--border); padding-top: 0.15rem;">
                    <span style="font-family: var(--font-mono); font-size: 0.42rem; font-weight: 800; color: var(--text-soft); display: block; margin-bottom: 0.02rem;">STACK:</span>
                    <span style="font-family: var(--font-mono); font-size: 0.46rem; font-weight: 700; color: var(--role-aidlc);">{study.techStack}</span>
                  </div>
                </div>
                
                <!-- Card Right: In-depth technical objectives, outcomes, and academic references -->
                <div style="display: flex; flex-direction: column; gap: 0.25rem; justify-content: center;">
                  <div style="display: flex; flex-direction: column; gap: 0.02rem;">
                    <span style="font-family: var(--font-mono); font-size: 0.42rem; font-weight: 800; color: var(--accent-strong); text-transform: uppercase; opacity: 0.85;">
                      {locale === "ko" ? "학습 목표 (OBJECTIVE):" : "OBJECTIVE:"}
                    </span>
                    <p style="font-size: 0.52rem; line-height: 1.25; color: var(--text); margin: 0; word-break: keep-all;">{study.objective}</p>
                  </div>
                  <div style="display: flex; flex-direction: column; gap: 0.02rem;">
                    <span style="font-family: var(--font-mono); font-size: 0.42rem; font-weight: 800; color: var(--accent-strong); text-transform: uppercase; opacity: 0.85;">
                      {locale === "ko" ? "주요 성과 (KEY OUTCOMES):" : "KEY OUTCOMES:"}
                    </span>
                    <p style="font-size: 0.52rem; line-height: 1.25; color: var(--text); margin: 0; word-break: keep-all;">{study.outcomes}</p>
                  </div>
                  <div style="display: flex; flex-direction: column; gap: 0.02rem;">
                    <span style="font-family: var(--font-mono); font-size: 0.42rem; font-weight: 800; color: var(--role-nlp); text-transform: uppercase; opacity: 0.85;">
                      {locale === "ko" ? "핵심 배움 (LESSONS LEARNED):" : "LESSONS LEARNED:"}
                    </span>
                    <p style="font-size: 0.52rem; line-height: 1.25; color: var(--text-soft); margin: 0; word-break: keep-all; font-style: italic;">"{study.takeaway}"</p>
                  </div>
                  <div style="display: flex; flex-direction: column; gap: 0.02rem; border-top: 1px dashed var(--border); padding-top: 0.12rem; margin-top: 0.08rem;">
                    <span style="font-family: var(--font-mono); font-size: 0.42rem; font-weight: 800; color: var(--accent-strong); text-transform: uppercase; opacity: 0.85;">
                      {locale === "ko" ? "연계 문헌 (RESEARCH REFERENCE):" : "RESEARCH REFERENCE:"}
                    </span>
                    <p style="font-size: 0.52rem; line-height: 1.25; color: var(--text-soft); margin: 0; word-break: keep-all; font-family: var(--font-mono); font-weight: 700;">{study.reference}</p>
                  </div>
                </div>
                
              </div>
            ))}
          </div>
        </section>
      </div>

    </div>

    <footer class="portfolio-print-cover__footer">
      {contactItems.slice(0, 3).map((item) => (
        <div>
          <span>{item.label}</span>
          <strong>{item.value}</strong>
        </div>
      ))}
    </footer>
  </article>
  </div>
</PrintLayout>
