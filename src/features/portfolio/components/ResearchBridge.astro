---
const { items } = Astro.props;
---

<div class="portfolio-research-list">
  {items.map(({ entry, linkedCases, primaryTheme, secondaryThemes }: { entry: any; linkedCases: string[]; primaryTheme: string; secondaryThemes: string[] }) => (
    <article class="portfolio-research-item" data-reveal="1" data-portfolio-card data-primary-theme={primaryTheme} data-secondary-themes={secondaryThemes?.join(" ")}>
      <span>{entry.data.venue} / {entry.data.year}</span>
      <h3>{entry.data.title}</h3>
      <p>{entry.data.portfolioRelevance ?? entry.data.contributionClaim ?? entry.data.abstract}</p>
      {linkedCases.length > 0 && (
        <p class="portfolio-research-item__case">{linkedCases.join(" · ")}</p>
      )}
    </article>
  ))}
</div>
