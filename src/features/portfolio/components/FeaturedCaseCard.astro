---
import ExternalLinks from "../../../components/common/ExternalLinks.astro";

const { item, labels, locale, featured = false } = Astro.props;
---

<article class:list={["portfolio-case-card", featured && "portfolio-case-card--hero"]} data-reveal="1">
  <div class="portfolio-case-card__main">
    <p class="portfolio-case-card__kicker">{item.type} / {item.year}</p>
    <h3>{item.title}</h3>
    <p class="portfolio-case-card__thesis">{item.thesis}</p>
    <div class="portfolio-case-card__panels">
      <section>
        <span>{labels.problem}</span>
        <p>{item.problem}</p>
      </section>
      <section>
        <span>{labels.decision}</span>
        <p>{item.decisions[0]?.description}</p>
      </section>
      <section>
        <span>{labels.outcome}</span>
        <p>{item.outcome}</p>
      </section>
    </div>
  </div>
  <aside class="portfolio-case-card__aside">
    <div>
      <span class="small-label">{labels.evidence}</span>
      {item.metrics.slice(0, 3).map((metric: { value: string; context?: string; label: string }) => (
        <article class="portfolio-case-card__metric">
          <strong>{metric.value}</strong>
          <span>{metric.context ?? metric.label}</span>
        </article>
      ))}
    </div>
    {item.artifacts.length > 0 && (
      <ExternalLinks
        locale={locale}
        links={item.artifacts.map((artifact: { label: string; href: string }) => ({ label: artifact.label, href: artifact.href }))}
      />
    )}
    <a class="button-link" href={item.href}>{labels.readCase}</a>
  </aside>
</article>
