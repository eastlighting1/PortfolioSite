---
import { entrySlug } from "../../../lib/content";
import { withBase } from "../../../lib/site";
import { localizePath, type Locale } from "../../../lib/i18n";
import { getProjectProofSentence } from "../../evidence/evidence-priority";
import { getPublicDisclosureLabel, getPublicEvidenceLevelLabel, getThemeById, normalizeEvidenceMetadata } from "../../portfolio/portfolio-data";

interface Props {
  projects: any[];
  eyebrow: string;
  title: string;
  lead?: string;
  locale?: Locale;
}

const { projects, eyebrow, title, lead, locale = "ko" } = Astro.props;
const labels =
  locale === "ko"
    ? { why: "확인할 내용", status: "공개 범위", open: "프로젝트 보기" }
    : { why: "What to check", status: "Availability", open: "Open project" };
---

<section class="section diagnostic-evidence" aria-labelledby="diagnostic-evidence-title">
  <div class="container">
    <div class="eyebrow">{eyebrow}</div>
    <h2 id="diagnostic-evidence-title" class="section-title" set:html={title} />
    {lead && <p class="section-lead diagnostic-evidence__lead" set:html={lead} />}
    <div class="diagnostic-evidence__grid">
      {projects.map((project) => {
        const slug = entrySlug(project);
        const evidence = normalizeEvidenceMetadata({ project: { ...project, slug }, locale });
        const theme = getThemeById(evidence.primaryTheme, locale);
        const proof = getProjectProofSentence({ ...project, slug }, locale);
        const status = `${getPublicEvidenceLevelLabel(evidence.evidenceLevel, locale)} / ${getPublicDisclosureLabel(evidence.disclosureLevel, locale)}`;

        return (
          <article class="diagnostic-evidence-card" data-primary-theme={evidence.primaryTheme}>
            <div>
              <span class="diagnostic-evidence-card__role">{theme.shortTitle}</span>
              <h3>{project.data.title}</h3>
              <p>{project.data.portfolio?.problem ?? project.data.portfolioProblem ?? project.data.summary}</p>
            </div>
            <dl>
              <div>
                <dt>{labels.why}</dt>
                <dd>{proof}</dd>
              </div>
              <div>
                <dt>{labels.status}</dt>
                <dd>{status}</dd>
              </div>
            </dl>
            <a class="button-link" href={withBase(localizePath(`projects/${slug}/`, locale))}>{labels.open}</a>
          </article>
        );
      })}
    </div>
  </div>
</section>

<style>
  .diagnostic-evidence__lead {
    max-width: 88ch;
  }

  .diagnostic-evidence__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .diagnostic-evidence-card {
    display: grid;
    grid-template-rows: 1fr auto auto;
    gap: 1rem;
    min-height: 24rem;
    padding: 1.15rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    box-shadow: var(--shadow-card);
  }

  .diagnostic-evidence-card__role {
    color: var(--color-accent);
    font-size: var(--font-size-sm);
    font-weight: 800;
    text-transform: uppercase;
  }

  .diagnostic-evidence-card h3 {
    margin: 0.65rem 0 0;
    line-height: 1.3;
  }

  .diagnostic-evidence-card p,
  .diagnostic-evidence-card dd {
    color: var(--color-text-muted);
  }

  .diagnostic-evidence-card dl {
    display: grid;
    gap: 0.75rem;
    margin: 0;
  }

  .diagnostic-evidence-card dt {
    color: var(--color-text);
    font-size: var(--font-size-xs);
    font-weight: 800;
    text-transform: uppercase;
  }

  .diagnostic-evidence-card dd {
    margin: 0.25rem 0 0;
    line-height: 1.5;
  }

  @media (max-width: 980px) {
    .diagnostic-evidence__grid {
      grid-template-columns: 1fr;
    }

    .diagnostic-evidence-card {
      min-height: 0;
    }
  }
</style>
