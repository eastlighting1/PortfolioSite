---
import { getGlobalEntry } from "../../../lib/content";
import { type Locale } from "../../../lib/i18n";
import { getRoleThemes } from "../../portfolio/portfolio-data";

interface Props {
  eyebrow: string;
  title: string;
  locale?: Locale;
}

const { eyebrow, title, locale = "ko" } = Astro.props;
const profileEntry = await getGlobalEntry("profile", locale);
const profile = profileEntry.data;
const roleThemes = getRoleThemes(locale);
---

<section class="section">
  <div class="container">
    <div class="section-head">
      <div class="eyebrow">{eyebrow}</div>
      <h2 class="section-title" set:html={title} />
    </div>
    <div class="capability-grid">
      {roleThemes.map((group, index) => (
        <article class="capability-card card-paper" data-reveal={`${(index % 4) + 1}`}>
          <div class="capability-card__content">
            <h3 class="capability-card__title">{group.title}</h3>
            <p class="capability-card__desc">{group.description}</p>
            <p class="muted">{group.businessSignal}</p>
          </div>
          <div class="capability-card__tags">
            {group.skills.slice(0, 4).map((skill) => (
              <span class="tag-chip">{skill}</span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .capability-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .capability-card {
    display: grid;
    grid-template-rows: 1fr auto;
  }

  .capability-card__tags {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.5rem;
  }

  .capability-card__tags .tag-chip {
    width: 100%;
    min-height: 2.4rem;
    padding-inline: 0.45rem;
    white-space: normal;
  }

  @media (max-width: 980px) {
    .capability-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
