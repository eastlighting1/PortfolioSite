---
import { getGlobalEntry } from "../../../lib/content";
import { withBase } from "../../../lib/site";
import { localizePath, type Locale } from "../../../lib/i18n";

interface Props {
  eyebrow: string;
  title: string;
  ctaLabel: string;
  count: number;
  locale?: Locale;
}

const { eyebrow, title, ctaLabel, count, locale = "ko" } = Astro.props;
const experienceEntry = await getGlobalEntry("experience", locale);
const experience = experienceEntry.data.items;
---

<section class="section">
  <div class="container">
    <div class="section-head">
      <div class="eyebrow">{eyebrow}</div>
      <h2 class="section-title" set:html={title} />
    </div>
    <div class="experience-snapshot-grid">
      {experience.slice(0, count).map((item, index) => (
        <article class="snapshot-card card-paper" data-reveal={`${(index % 4) + 1}`}>
          <span class="snapshot-card__period">{item.period}</span>
          <h3 class="snapshot-card__role">{item.role}</h3>
          <p class="snapshot-card__org">{item.organization}</p>
          <p class="snapshot-card__summary">{item.bullets[0]}</p>
        </article>
      ))}
    </div>
    <div class="section-cta-row">
      <a class="button-link-secondary" href={withBase(localizePath("/resume/", locale))}>{ctaLabel}</a>
    </div>
  </div>
</section>
