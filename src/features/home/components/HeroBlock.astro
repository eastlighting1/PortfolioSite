---
import { getGlobalEntry } from "../../../lib/content";
import { withBase } from "../../../lib/site";
import { localizePath, type Locale } from "../../../lib/i18n";
import { getRoleThemes } from "../../portfolio/portfolio-data";

interface Props {
  eyebrow: string;
  summary: string;
  actions: {
    label: string;
    href: string;
    variant: "primary" | "secondary";
  }[];
  focusCard: {
    label: string;
    title: string;
    body: string;
    items: {
      label: string;
      value: string;
    }[];
  };
  locale?: Locale;
}

const { eyebrow, summary, actions, focusCard, locale = "ko" } = Astro.props;
const profileEntry = await getGlobalEntry("profile", locale);
const siteEntry = await getGlobalEntry("site", locale);
const profile = profileEntry.data;
const siteConfig = siteEntry.data;
const roleThemes = getRoleThemes(locale);
const localizeHref = (href: string) => {
  const [withoutHash, hash = ""] = href.split("#");
  const [path, query = ""] = withoutHash.split("?");
  return withBase(`${localizePath(path, locale)}${query ? `?${query}` : ""}${hash ? `#${hash}` : ""}`);
};
const roleLensHref = (roleId: string) => localizeHref(`/portfolio/?lens=${roleId}#valueMap`);
---

<section class="section">
  <div class="container">
    <div class="hero-panel card-paper card-paper--hero">
      <div>
        <div class="eyebrow" data-reveal="1">{eyebrow}</div>
        <h1 class="hero-title" data-reveal="2">{siteConfig.primaryRole}</h1>
        <p class="hero-copy" data-reveal="3" set:html={summary} />
        <p class="hero-copy" data-reveal="4" set:html={profile.intro} />
        <div class="chip-row" data-reveal="4">
          {roleThemes.map((role) => (
            <span class="role-chip">{role.shortTitle}</span>
          ))}
        </div>
        <div class="hero-actions" data-reveal="4">
          {actions.map((action) => (
            <a
              class={action.variant === "primary" ? "button-link" : "button-link-secondary"}
              href={localizeHref(action.href)}
            >
              {action.label}
            </a>
          ))}
        </div>
      </div>
      <aside class="hero-role-map" data-reveal="4" aria-label={focusCard.label}>
        {roleThemes.map((role) => (
          <a class="hero-role-map__item" href={roleLensHref(role.id)}>
            <span>{role.shortTitle}</span>
            <strong>{role.title}</strong>
            <p>{role.businessSignal}</p>
          </a>
        ))}
      </aside>
    </div>
  </div>
</section>
