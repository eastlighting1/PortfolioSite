---
import { getGlobalEntry } from "../../../lib/content";
import { withBase } from "../../../lib/site";
import { localizePath, type Locale } from "../../../lib/i18n";

interface Props {
  eyebrow: string;
  summary: string;
  actions: {
    label: string;
    href: string;
    variant: "primary" | "secondary";
  }[];
  focusCard: {
    label: string;
    title: string;
    body: string;
    items: {
      label: string;
      value: string;
    }[];
  };
  locale?: Locale;
}

const { eyebrow, summary, actions, focusCard, locale = "ko" } = Astro.props;
const profileEntry = await getGlobalEntry("profile", locale);
const siteEntry = await getGlobalEntry("site", locale);
const profile = profileEntry.data;
const siteConfig = siteEntry.data;
---

<section class="section">
  <div class="container">
    <div class="hero-panel card-paper card-paper--hero">
      <div>
        <div class="eyebrow" data-reveal="1">{eyebrow}</div>
        <h1 class="hero-title" data-reveal="2">{profile.name}</h1>
        <p class="hero-copy" data-reveal="3" set:html={summary} />
        <p class="hero-copy" data-reveal="4" set:html={profile.intro} />
        <div class="chip-row" data-reveal="4">
          <span class="role-chip">{siteConfig.primaryRole}</span>
          {siteConfig.secondaryRoles.map((role) => (
            <span class="role-chip">{role}</span>
          ))}
        </div>
        <div class="hero-actions" data-reveal="4">
          {actions.map((action) => (
            <a
              class={action.variant === "primary" ? "button-link" : "button-link-secondary"}
              href={withBase(localizePath(action.href, locale))}
            >
              {action.label}
            </a>
          ))}
        </div>
      </div>
      <aside class="hero-focus" data-reveal="4">
        <span class="hero-focus__label">{focusCard.label}</span>
        <h2 class="hero-focus__title" set:html={focusCard.title} />
        <p class="hero-focus__body" set:html={focusCard.body} />
        <dl class="hero-focus__list">
          {focusCard.items.map((item) => (
            <div class="hero-focus__item">
              <dt>{item.label}</dt>
              <dd>{item.value}</dd>
            </div>
          ))}
        </dl>
      </aside>
    </div>
  </div>
</section>
