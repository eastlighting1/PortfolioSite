---
import ResearchCard from "../../research/components/ResearchCard.astro";
import { type Locale } from "../../../lib/i18n";

interface Props {
  research: any[];
  eyebrow: string;
  title: string;
  lead?: string;
  locale?: Locale;
}

const { research, eyebrow, title, lead, locale = "ko" } = Astro.props;
---

<section class="section">
  <div class="container">
    <div class="eyebrow">{eyebrow}</div>
    <h2 class="section-title" set:html={title} />
    {lead && <p class="section-lead" set:html={lead} />}
    <div class="research-list" style="margin-top: 2rem;">
      {research.map((item, index) => (
        <ResearchCard item={item} dataReveal={`${(index % 4) + 1}`} locale={locale} />
      ))}
    </div>
  </div>
</section>
