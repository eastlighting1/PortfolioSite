---
import { withBase } from "../../../lib/site";
import { localizePath, type Locale } from "../../../lib/i18n";

interface Props {
  eyebrow: string;
  title: string;
  cards: {
    label: string;
    title: string;
    body: string;
    href: string;
    ctaLabel: string;
  }[];
  locale?: Locale;
}

const { eyebrow, title, cards, locale = "ko" } = Astro.props;
---

<section class="section">
  <div class="container">
    <div class="section-head">
      <div class="eyebrow">{eyebrow}</div>
      <h2 class="section-title" set:html={title} />
    </div>
    <div class="document-cta-grid">
      {cards.map((card, index) => (
        <article class="document-card card-paper" data-reveal={`${index + 1}`}>
          <span class="document-card__label">{card.label}</span>
          <h3 class="document-card__title">{card.title}</h3>
          <p class="document-card__body">{card.body}</p>
          <a class="document-card__cta" href={withBase(localizePath(card.href, locale))}>{card.ctaLabel}</a>
        </article>
      ))}
    </div>
  </div>
</section>
