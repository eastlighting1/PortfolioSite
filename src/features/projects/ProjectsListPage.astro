---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/common/PageHero.astro";
import ProjectGrid from "./components/ProjectGrid.astro";
import { getLocalizedCollection, getPageEntry } from "../../lib/content";
import { type Locale } from "../../lib/i18n";

interface Props {
  locale: Locale;
  pathname: string;
}

const { locale, pathname } = Astro.props;

const projectsPage = await getPageEntry("projects", locale);
if (projectsPage.data.pageType !== "projects") {
  throw new Error("Missing projects page content configuration.");
}

const projects = (await getLocalizedCollection("projects", locale)).sort((a, b) => b.data.year - a.data.year);
const projectCountLabel = locale === "ko" ? `프로젝트 ${projects.length}건` : `${projects.length} projects`;
const heroMeta = [projectCountLabel, ...projectsPage.data.hero.meta];
---

<BaseLayout
  title={projectsPage.data.documentTitle}
  description={projectsPage.data.documentDescription}
  pathname={pathname}
  locale={locale}
>
  <section class="section">
    <div class="container">
      <PageHero
        eyebrow={projectsPage.data.hero.eyebrow}
        title={projectsPage.data.hero.title}
        description={projectsPage.data.hero.description}
        meta={heroMeta}
      />
      <div class="section-tight">
        <ProjectGrid projects={projects} locale={locale} />
      </div>
    </div>
  </section>
</BaseLayout>
