---
import { getUiEntry } from "../../../lib/content";
import ExternalLinks from "../../../components/common/ExternalLinks.astro";
import { type Locale } from "../../../lib/i18n";
import { entrySlug } from "../../../lib/content";
import {
  getPublicDisclosureLabel,
  getPublicEvidenceLevelLabel,
  getThemeById,
  normalizeEvidenceMetadata
} from "../../portfolio/portfolio-data";

interface Props {
  project: any;
  locale?: Locale;
}

const { project, locale = "ko" } = Astro.props;
const uiEntry = await getUiEntry("labels", locale);
const ui = uiEntry.data;
const evidence = normalizeEvidenceMetadata({ project: { ...project, slug: entrySlug(project) }, locale });
const theme = getThemeById(evidence.primaryTheme, locale);
const statusLabel = getPublicEvidenceLevelLabel(evidence.evidenceLevel, locale);
const availabilityLabel = evidence.disclosureLevel === "Public" ? "" : getPublicDisclosureLabel(evidence.disclosureLevel, locale);
---

<section class="detail-hero" data-reveal="1">
  <div class="eyebrow">{ui.project.detailEyebrow}</div>
  <h1 class="section-title">{project.data.title}</h1>
  <p class="section-lead">{project.data.portfolio?.thesis ?? project.data.summary}</p>
  <div class="meta-list">
    <div class="meta-item">
      <span>{ui.project.fieldLabels.type}</span>
      <span>{project.data.type}</span>
    </div>
    <div class="meta-item">
      <span>{ui.project.fieldLabels.year}</span>
      <span>{project.data.year}</span>
    </div>
    <div class="meta-item">
      <span>{ui.project.fieldLabels.primaryRole}</span>
      <span>{project.data.role}</span>
    </div>
    <div class="meta-item">
      <span>{ui.project.fieldLabels.roles}</span>
      <span>{project.data.roles.join(", ")}</span>
    </div>
  </div>
  <div class="tag-row" style="margin-top: 1rem;">
    <span class="tag-chip">{theme.title}</span>
    <span class="tag-chip">{statusLabel}</span>
    {availabilityLabel && <span class="tag-chip tag-chip--muted">{availabilityLabel}</span>}
    {project.data.tags.map((tag: string) => (
      <span class="tag-chip">{tag}</span>
    ))}
  </div>
  <p class="section-lead" style="margin-top: 1rem;">{evidence.businessSignal}</p>
  <div class="tag-row" style="margin-top: 1rem;" aria-label={locale === "ko" ? "데이터 표면" : "Data surfaces"}>
    {evidence.dataSurfaces.map((surface: string) => (
      <span class="tag-chip">{surface}</span>
    ))}
  </div>
  <div class="tag-row" style="margin-top: 1rem;" aria-label={locale === "ko" ? "AI-DLC 적용 단계" : "AI-DLC coverage"}>
    {evidence.workflowStages.map((stage: string) => (
      <span class="metric-badge">{stage}</span>
    ))}
  </div>
  <div class="meta-row" style="margin-top: 1rem;">
    {project.data.metrics.map((metric: string) => (
      <span class="metric-badge">{metric}</span>
    ))}
  </div>
  <ExternalLinks
    locale={locale}
    links={[
      { label: ui.project.linkLabels.repo, href: project.data.repoUrl },
      { label: ui.project.linkLabels.demo, href: project.data.demoUrl },
      { label: ui.project.linkLabels.paper, href: project.data.paperUrl },
      { label: ui.project.linkLabels.slides, href: project.data.slidesUrl }
    ]}
  />
</section>
